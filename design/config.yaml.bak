# ═══════════════════════════════════════════════════════════
# КОНТЕНТ-ЗАВОД ЗИНАИДА — ДИЗАЙН-КОНФИГУРАЦИЯ
# ═══════════════════════════════════════════════════════════

brand:
  name: "Зинаида"
  niche: "Мужская психология / Отношения"
  target_audience: "Женщины 18-40"
  tone: "уверенный, экспертный, провокационный, тёплый"
  colors:
    primary: "#1A1A1A"        # чёрный
    accent_bordeaux: "#8B0000"  # бордовый
    gold: "#C9A84C"           # тёплое золото
    warm_beige: "#F5E6D0"     # тёплый беж
    deep_blue: "#1B2A4A"      # глубокий синий
    dark_brown: "#5C1A1A"     # тёмный бордовый
  fonts:
    heading: "Playfair Display / Didone serif"
    body: "Inter / Montserrat"
    quote_italic: "Cormorant Garamond Italic"
    prompt_description: "elegant high-contrast serif font, Didone style, white text, thin serifs, bold vertical strokes"
  logo_style: "маленький ♦ или текстовый «З»"

models:
  text_heavy:
    name: "Recraft V3"
    id: "recraft-ai/recraft-v3"
    price_per_image: 0.04
    use_for: "Вариант 1 (журнальная обложка) и Вариант 2 (цитата)"
    notes: "Лучшая кириллица среди всех моделей"
  photorealistic:
    name: "FLUX dev + LoRA"
    id: "black-forest-labs/flux-dev-lora"
    price_per_image: 0.025
    lora: "Muapi/russian-text-flux"
    use_for: "Вариант 3 (кино-сцена с персонажами)"
    notes: "Фотореализм + кириллица через LoRA"
  backup:
    name: "Ideogram v3 Turbo"
    id: "ideogram-ai/ideogram-v3-turbo"
    price_per_image: 0.03
    use_for: "Запасной вариант для текста"
    notes: "90-95% точность кириллицы, дешевле Recraft"
  drafts:
    name: "FLUX Schnell"
    id: "black-forest-labs/flux-schnell"
    price_per_image: 0.003
    use_for: "Черновики и быстрые тесты"
    notes: "Самый дешёвый, текст не умеет"

formats:
  post_square: "1080x1080"
  carousel_vertical: "1080x1350"
  story_vertical: "1080x1920"

budget:
  max_per_week_usd: 2.00
  generations_per_post: 3
  startup_bonus_usd: 5.00

content_mix:
  variant_1_magazine: 0.60    # 60% — журнальная обложка
  variant_2_quote: 0.25       # 25% — цитата-провокация
  variant_3_scene: 0.15       # 15% — кино-сцена

characters:
  zinaida:
    role: "Эксперт, автор, лицо бренда"
    usage: "Только Вариант 1 — затемнённый фон"
    never: "НЕ ставить в драматические сцены с мужчиной"
    appearance: "тёмные волосы с рыжими кончиками, белая рубашка, AR-очки"
  male_types:
    - type: "Альфа"
      look: "уверенный, в костюме, серьёзный взгляд"
      lighting: "контрастное, холодное"
    - type: "Ранимый"
      look: "домашняя одежда, задумчивый, у окна"
      lighting: "мягкое, тёплое"
    - type: "Токсичный"
      look: "тёмный свет, резкие тени, отворачивается"
      lighting: "тёмное, драматичное"
    - type: "Любящий"
      look: "мягкий свет, тянет руку, тёплые тона"
      lighting: "golden hour, боке"

emotions_priority:
  - emotion: "Задумчивость"
    percent: 50
  - emotion: "Раскаяние / сожаление"
    percent: 20
  - emotion: "Одиночество"
    percent: 15
  - emotion: "Нежность"
    percent: 10
  - emotion: "Агрессия/контроль"
    percent: 5

paths:
  design_root: "/opt/zinaida/design"
  references: "/opt/zinaida/design/references"
  generated: "/opt/zinaida/design/generated"
  approved: "/opt/zinaida/design/approved"
  templates: "/opt/zinaida/design/templates"
  passport: "/opt/zinaida/design/passport"
  photos_zinaida: "/opt/zinaida/design/references/zinaida_face"

api:
  replicate_token_env: "REPLICATE_API_TOKEN"
  env_file: "/opt/zinaida/config/secrets.env"
