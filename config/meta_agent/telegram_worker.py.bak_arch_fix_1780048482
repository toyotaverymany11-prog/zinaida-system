import os, requests, base64, logging, telebot

logging.basicConfig(
    filename='/opt/zinaida/logs/telegram_worker.log',
    level=logging.INFO,
    format='%(asctime)s - %(levelname)s - %(message)s'
)
logger = logging.getLogger(__name__)

TOKEN = os.getenv('TELEGRAM_TOKEN', '8560310319:AAFFS5ubSS0FQI8xowTl9TCg3UrOw6J3pIk')
ZINAIDA_URL = "http://127.0.0.1:8002/v1/chat/completions"
GRIGORIY_URL = "http://127.0.0.1:8003/v1/chat/completions"
CODE_KEYWORDS = ["код", "скрипт", "python", "напиши программу", "исправь", "рефакторинг", "выполни", "григорий"]

bot = telebot.TeleBot(TOKEN)

def route_request(text, payload=None):
    is_code = any(kw in text.lower() for kw in CODE_KEYWORDS)
    url = GRIGORIY_URL if is_code else ZINAIDA_URL
    target = "Grigoriy :8003" if is_code else "Zinaida :8002"
    logger.info(f'Routing to {target}')
    try:
        resp = requests.post(url, json=payload, timeout=45)
        resp.raise_for_status()
        return resp.json().get('choices', [{}])[0].get('message', {}).get('content', 'Нет ответа')
    except Exception as e:
        logger.error(f'Route error ({target}): {e}')
        if is_code:
            logger.info('Fallback from Grigoriy to Zinaida')
            resp = requests.post(ZINAIDA_URL, json=payload, timeout=45)
            return resp.json().get('choices', [{}])[0].get('message', {}).get('content', 'Ошибка')
        return 'Извините, произошла ошибка при обработке.'

@bot.message_handler(commands=['start'])
def start(message):
    bot.reply_to(message, 'Привет! Я Зинаида. Отправь текст, фото или попроси написать код (Григорий подключится автоматически).')

@bot.message_handler(content_types=['text'])
def handle_text(message):
    payload = {"messages": [{"role": "user", "content": message.text}], "stream": False}
    reply = route_request(message.text, payload)
    bot.reply_to(message, reply)

@bot.message_handler(content_types=['photo'])
def handle_photo(message):
    try:
        file_info = bot.get_file(message.photo[-1].file_id)
        downloaded = bot.download_file(file_info.file_path)
        b64 = base64.b64encode(downloaded).decode('utf-8')
        text = message.caption or "Проанализируй это изображение"
        payload = {
            "messages": [{
                "role": "user",
                "content": [
                    {"type": "text", "text": text},
                    {"type": "image_url", "image_url": {"url": f"data:image/jpeg;base64,{b64}"}}
                ]
            }],
            "stream": False
        }
        reply = route_request(text, payload)
        bot.reply_to(message, reply)
    except Exception as e:
        logger.error(f'Photo error: {e}')
        bot.reply_to(message, 'Ошибка при анализе изображения.')

if __name__ == '__main__':
    logger.info('Smart Telegram worker starting...')
    bot.infinity_polling(timeout=60, long_polling_timeout=30)
