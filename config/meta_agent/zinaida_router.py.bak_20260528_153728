import os, json, requests, time, sys
from fastapi import FastAPI, Request
from fastapi.responses import JSONResponse

app = FastAPI()
CORE_PATH = "/opt/zinaida/memory/knowledge/CORE.md"
SNAPSHOT_PATH = "/root/workspace/SYSTEM_SNAPSHOT.md"
NICHES_DIR = "/root/workspace/niches"

PROVIDERS = [
    {"name": "zhipu", "url": "https://open.bigmodel.cn/api/paas/v4/chat/completions", "key": os.getenv("ZHIPU_API_KEY",""), "model": "glm-4-flash"},
    {"name": "github", "url": "https://models.inference.ai.azure.com/chat/completions", "key": os.getenv("GITHUB_TOKEN",""), "model": "gpt-4o-mini"},
    {"name": "openrouter", "url": "https://openrouter.ai/api/v1/chat/completions", "key": os.getenv("OPENROUTER_API_KEY",""), "model": "mistralai/mistral-7b-instruct:free"},
    {"name": "gigachat", "url": "https://gigachat.devices.sberbank.ru/api/v1/chat/completions", "key": os.getenv("GIGACHAT_TOKEN",""), "model": "GigaChat"},
    {"name": "mistral", "url": "https://api.mistral.ai/v1/chat/completions", "key": os.getenv("MISTRAL_API_KEY",""), "model": "mistral-small-latest"}
]

def load_file(path):
    try:
        with open(path, 'r', encoding='utf-8') as f: return f.read()
    except Exception: return ""

def build_system_prompt(user_text, niche_id=None):
    core = load_file(CORE_PATH) or "Ты — Зинаида, руководитель маркетингового агентства. Говори в женском роде."
    
    # ТРИГГЕР [СИСТЕМА]: игнорирует нишу, грузит слепок
    if user_text.strip().upper().startswith("[СИСТЕМА]"):
        snapshot = load_file(SNAPSHOT_PATH) or "[Слепок системы недоступен]"
        return f"{core}\n\n[СИСТЕМНЫЙ РЕЖИМ]\nТекущее состояние сервера и компонентов:\n{snapshot}\n\nОтветь кратко, по делу, используя только факты из слепка. Не выдумывай статусы."
    
    # Стандартная сборка промпта для ниш
    prompt = core
    if niche_id:
        brief = load_file(os.path.join(NICHES_DIR, niche_id, "brief.md"))
        tone = load_file(os.path.join(NICHES_DIR, niche_id, "tone.md"))
        if brief: prompt += f"\n\n[КОНТЕКСТ НИШИ]\n{brief}"
        if tone: prompt += f"\n\n[СТИЛЬ И ОГРАНИЧЕНИЯ]\n{tone}"
    return prompt

def call_provider(messages, system_prompt):
    payload_msgs = [{"role": "system", "content": system_prompt}] + messages
    for p in PROVIDERS:
        if not p["key"]: continue
        try:
            headers = {"Authorization": f"Bearer {p['key']}", "Content-Type": "application/json"}
            if p["name"] == "openrouter": headers["HTTP-Referer"] = "https://zinaida.local"
            payload = {"model": p["model"], "messages": payload_msgs, "temperature": 0.4, "max_tokens": 1500}
            resp = requests.post(p["url"], json=payload, headers=headers, timeout=25)
            if resp.status_code == 200:
                data = resp.json()
                content = data.get("choices", [{}])[0].get("message", {}).get("content", "")
                if content: return content
        except Exception:
            continue
    return "[ОШИБКА: Все провайдеры недоступны. Проверь ключи и сеть.]"

@app.get("/health")
def health():
    return {"status":"ok","router":"zinaida_with_provider_fallback_v1"}

@app.post("/v1/chat/completions")
async def chat(request: Request):
    try:
        data = await request.json()
        messages = data.get("messages", [])
        user_text = messages[-1].get("content", "") if messages else ""
        niche_id = data.get("niche_id") or request.headers.get("x-niche-id")
        
        system_prompt = build_system_prompt(user_text, niche_id)
        reply = call_provider(messages, system_prompt)
        
        return JSONResponse({
            "choices": [{"message": {"role": "assistant", "content": reply}}],
            "model": "zinaida-router",
            "usage": {"total_tokens": 0}
        })
    except Exception as e:
        return JSONResponse({"error": str(e)}, status_code=500)

if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8002)
