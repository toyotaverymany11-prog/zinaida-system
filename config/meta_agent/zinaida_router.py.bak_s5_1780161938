def extract_text_and_media(messages: List[Dict[str, Any]]) -> tuple:
    full_text = []
    has_media = False
    for msg in messages:
        content = msg.get('content', '')
        if isinstance(content, str):
            full_text.append(content)
        elif isinstance(content, list):
            for part in content:
                if isinstance(part, dict):
                    ptype = part.get('type', '')
                    if ptype == 'text':
                        full_text.append(part.get('text', ''))
                    elif ptype in ('image_url', 'file', 'image'):
                        has_media = True
    return ' '.join(full_text).strip(), has_media

def get_rag_context(text: str) -> str:
    try:
        from knowledge_search import search
        return search(text)
    except Exception:
        return ""

def build_system_prompt(user_text: str, niche_id: str = None) -> str:
    core = load_core()
    rag = get_rag_context(user_text)
    prompt = core
    if rag:
        prompt += f"\n\n[КОНТЕКСТ ИЗ ПАМЯТИ]\n{rag}"
    if user_text.strip().upper().startswith('[СИСТЕМА]'):
        try:
            with open('/opt/zinaida/memory/SYSTEM_SNAPSHOT.md', 'r', encoding='utf-8') as f:
                snap = f.read()
        except Exception:
            snap = '[Слепок недоступен]'
        prompt += f"\n\n[СИСТЕМНЫЙ РЕЖИМ]\n{snap}\n\nОтветь кратко."
    return prompt

def call_provider_sync(messages: List[Dict], system_prompt: str, provider: Dict) -> str:
    headers = provider.get('headers', {})
    payload = {
        'model': provider['model'],
        'messages': [{'role': 'system', 'content': system_prompt}] + messages,
        'temperature': 0.7
    }
    try:
        resp = requests.post(provider['url'], json=payload, headers=headers, timeout=25, verify=provider.get('verify', True))
        if resp.status_code == 200:
            data = resp.json()
            content = data.get('choices', [{}])[0].get('message', {}).get('content', '')
            if content:
                print(f"PROVIDER {provider.get('name', provider['model'])} OK")
                return content
        else:
            print(f"PROVIDER {provider.get('name', provider['model'])} -> {resp.status_code}: {resp.text[:100]}")
    except Exception as e:
        print(f"PROVIDER {provider.get('name', provider['model'])} ERROR: {e}")
    return None

def call_with_smart_routing(messages: List[Dict], system_prompt: str, force_vision: bool = False) -> str:
    text, _ = extract_text_and_media(messages)
    ctx_size = len(text)
    complexity = request_complexity_score(ctx_size, text)
    strategy = "analyze" if (force_vision or complexity > 0.7) else "filter"
    
    provider = get_provider(strategy, ctx_size, text)
    start_time = time.time()
    used_provider = "none"
    
    if provider:
        try:
            res = call_provider_sync(messages, system_prompt, provider)
            if res:
                used_provider = provider.get('name', provider.get('model', 'unknown'))
                latency = int((time.time() - start_time) * 1000)
                log_routing_event({"strategy": strategy, "provider": used_provider, "latency_ms": latency, "status": "ok", "context_size": ctx_size, "complexity_score": complexity})
                return res
        except Exception as e:
            print(f"SMART ROUTING ERROR: {e}")
            
    print("SMART ROUTING FALLBACK TO LEGACY")
    targets = LEGACY_PROVIDERS
    if force_vision:
        targets = [p for p in LEGACY_PROVIDERS if p.get('vision')] + [p for p in LEGACY_PROVIDERS if not p.get('vision')]
    for p in targets:
        res = call_provider_sync(messages, system_prompt, p)
        if res:
            used_provider = p['name']
            latency = int((time.time() - start_time) * 1000)
            log_routing_event({"strategy": strategy, "provider": used_provider, "latency_ms": latency, "status": "fallback_ok", "context_size": ctx_size, "complexity_score": complexity})
            return res
            
    latency = int((time.time() - start_time) * 1000)
    log_routing_event({"strategy": strategy, "provider": "none", "latency_ms": latency, "status": "all_failed", "context_size": ctx_size, "complexity_score": complexity})
    return "[ОШИБКА: Все провайдеры недоступны. Проверь ключи или сеть.]"

def stream_generator(messages: List[Dict], system_prompt: str, force_vision: bool = False):
    full = call_with_smart_routing(messages, system_prompt, force_vision)
    cid = f"chatcmpl-{uuid.uuid4().hex[:8]}"
    chunk = {'id': cid, 'object': 'chat.completion.chunk', 'created': int(time.time()), 'model': 'fallback', 'choices': [{'index': 0, 'delta': {'content': full}, 'finish_reason': 'stop'}]}
    yield f"data: {json.dumps(chunk)}\n\n"
    yield "data: [DONE]\n\n"

@app.get("/health")
def health():
    return {"status": "ok", "router": "zinaida_v5.4_smart_routing", "providers": ["smart_manager"] + [p['name'] for p in LEGACY_PROVIDERS]}

@app.post("/v1/chat/completions")
async def chat(request: Request):
    try:
        data = await request.json()
        messages = data.get('messages', [])
        if not messages:
            return JSONResponse(status_code=400, content={"error": "messages required"})
        extracted_text, has_media = extract_text_and_media(messages)
        stream = data.get('stream', False)
        sys_prompt = build_system_prompt(extracted_text)
        if stream:
            return StreamingResponse(stream_generator(messages, sys_prompt, force_vision=has_media), media_type="text/event-stream")
        reply = call_with_smart_routing(messages, sys_prompt, force_vision=has_media)
        return {"choices": [{"message": {"role": "assistant", "content": reply}}]}
    except Exception as e:
        print(f"ROUTER ERROR: {e}")
        return JSONResponse(status_code=500, content={"error": str(e)})

