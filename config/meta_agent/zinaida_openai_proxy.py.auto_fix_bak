import requests
from fastapi import FastAPI, Request
from fastapi.responses import StreamingResponse, JSONResponse
from fastapi.middleware.cors import CORSMiddleware
import uvicorn, time, uuid, json, sys, os

sys.path.insert(0, '/opt/zinaida/meta_agent')
try:
    from router_fallback import call_with_fallback
    print("✅ router_fallback loaded")
except Exception as e:
    print(f"❌ Import error: {e}")
    sys.exit(1)

app = FastAPI()
app.add_middleware(CORSMiddleware, allow_origins=["*"], allow_methods=["*"], allow_headers=["*"])

@app.get("/status")
def status(): return {"alive": True, "port": 8000}

# Функция для генерации потока (Streaming)
def stream_response(prompt: str, task_type: str):
    try:
        response_text = call_with_fallback(prompt, task_type=task_type)
        # Формируем chunks для SSE
        chunk = {
            "id": f"chatcmpl-{uuid.uuid4().hex[:8]}",
            "object": "chat.completion.chunk",
            "created": int(time.time()),
            "model": "glm-4-flash",
            "choices": [{"index": 0, "delta": {"content": response_text}, "finish_reason": "stop"}]
        }
        yield f"data: {json.dumps(chunk)}\n\n"
        yield "data: [DONE]\n\n"
    except Exception as e:
        print(f"Stream Error: {e}")

@app.post("/v1/chat/completions")
@app.post("/chat/completions")
async def chat(request: Request):
    try:
        data = await request.json()
        stream = data.get("stream", False)
        messages = data.get("messages", [])

    # === ПАМЯТЬ: ИЗВЛЕЧЕНИЕ КОНТЕКСТА ===
    memory_ctx = ""
    try:
        r = requests.post("http://localhost:8505/memory/recall", json={"query": messages[-1].get("content",""), "limit": 3}, timeout=2)
        if r.status_code == 200:
            res = r.json().get("results", [])
            if res:
                memory_ctx = "\n".join([f"- {x['content'][:300]}" for x in res])
    except Exception:
        pass
    if memory_ctx:
        sys_msg = next((m for m in messages if m.get("role")=="system"), None)
        if sys_msg:
            sys_msg["content"] += f"\n\n[ПАМЯТЬ]\n{memory_ctx}"
        else:
            messages.insert(0, {"role":"system", "content": f"[ПАМЯТЬ]\n{memory_ctx}"})
    # === КОНЕЦ ===
        prompt = messages[-1]["content"] if messages else "Hi"
        
        task_type = "code" if any(k in prompt.lower() for k in ["код", "python", "def ", "script"]) else "chat"
        
        # Если просят стриминг (как AnythingLLM)
        if stream:
            return StreamingResponse(stream_response(prompt, task_type), media_type="text/event-stream")
        
        # Если обычный запрос (как curl)
        response_text = call_with_fallback(prompt, task_type=task_type)
        return {
            "id": f"chatcmpl-{uuid.uuid4().hex[:8]}",
            "object": "chat.completion",
            "created": int(time.time()),
            "model": "glm-4-flash",
            "choices": [{"index": 0, "message": {"role": "assistant", "content": response_text}, "finish_reason": "stop"}],
            "usage": {"total_tokens": len(response_text.split())}
        }
    except Exception as e:
        return JSONResponse(status_code=500, content={"error": str(e)})

if __name__ == "__main__":
    uvicorn.run(app, host="0.0.0.0", port=8000)
