@app.post('/v1/chat/completions')
async def chat(request: Request, x_niche_id: str = Header(None)):
    try:
        data = await request.json()
        msgs = data.get('messages',[])
        if not msgs:
            return JSONResponse({'error':'messages required'}, status_code=400)
        extracted_text, has_media = extract_text_and_media(msgs)
        nid = data.get('niche_id') or x_niche_id
        stream = data.get('stream', False)
        if nid and not os.path.exists(os.path.join(NICHES_DIR, nid)):
            return JSONResponse(status_code=404, content={'error':f'Niche {nid} not found'})
        sys_prompt = build_system_prompt(extracted_text, nid)
        if stream:
            return StreamingResponse(stream_generator(msgs, sys_prompt, force_vision=has_media), media_type='text/event-stream')
                # === ДЕЛЕГИРОВАНИЕ НА ГРИГОРИЯ (:8003) ===
        x_internal = request.headers.get("x-internal-call", "")
        is_code_task = False
        if x_internal != "grigoriy":
            CODE_KEYWORDS = ["код", "скрипт", "python", "напиши программу", "исправь", "рефакторинг", "выполни", "григорий", "программу", "функцию"]
            _last_msg = msgs[-1] if msgs else {}
            _last_content = _last_msg.get("content", "")
            _user_text = _last_content if isinstance(_last_content, str) else str(_last_content)
            is_code_task = any(kw in _user_text.lower() for kw in CODE_KEYWORDS)
        if is_code_task:
            try:
                import httpx
                grigoriy_payload = {"messages": msgs, "stream": False}
                async with httpx.AsyncClient(timeout=20.0) as client:
                    gr_resp = await client.post("http://127.0.0.1:8003/v1/chat/completions", json=grigoriy_payload)
                    gr_resp.raise_for_status()
                    gr_data = gr_resp.json()
                    gr_reply = gr_data.get("choices", [{}])[0].get("message", {}).get("content", "")
                    if gr_reply:
                        logger.info("Delegated to Grigoriy :8003 OK")
                        reply = f"👔 [Григорий выполнил задачу]\n\n{gr_reply}"
                        return JSONResponse({"choices": [{"message": {"role": "assistant", "content": reply}}], "model": "zinaida-router", "usage": {"total_tokens": 0}})
            except Exception as e:
                logger.warning(f"Grigoriy delegation failed, fallback to Zinaida: {e}")
        # === КОНЕЦ ДЕЛЕГИРОВАНИЯ ===
        reply = call_with_fallback(msgs, sys_prompt, force_vision=has_media)
        return JSONResponse({'choices':[{'message':{'role':'assistant','content':reply}}],'model':'zinaida-router','usage':{'total_tokens':0}})
    except Exception as e:
        logger.error(f'Router error: {e}')
        return JSONResponse({'error':str(e)}, status_code=500)

