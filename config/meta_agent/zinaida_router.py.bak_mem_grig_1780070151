def load_core():
    try:
        with open(CORE_PATH, 'r', encoding='utf-8') as f: return f.read()
    except Exception as e:
        logger.error(f'CORE load fail: {e}')
        return 'Ты — Зинаида, руководитель маркетингового агентства. Говори в женском роде.'

def load_niche_context(niche_id):
    if not niche_id: return ''
    niche_dir = os.path.join(NICHES_DIR, niche_id)
    if not os.path.exists(niche_dir): return ''
    ctx = ''
    for fname, tag in [('brief.md', f'[КОНТЕКСТ НИШИ {niche_id}]'), ('tone.md', '[СТИЛЬ И ОГРАНИЧЕНИЯ]')]:
        fpath = os.path.join(niche_dir, fname)
        if os.path.exists(fpath):
            with open(fpath, 'r', encoding='utf-8') as f: ctx += f'\n\n{tag}\n{f.read()}'
    return ctx

def extract_text_and_media(messages):
    full_text = []
    has_media = False
    for msg in messages:
        content = msg.get('content', '')
        if isinstance(content, str):
            full_text.append(content)
        elif isinstance(content, list):
            for part in content:
                if isinstance(part, dict):
                    ptype = part.get('type', '')
                    if ptype == 'text':
                        full_text.append(part.get('text', ''))
                    elif ptype in ('image_url', 'file', 'image'):
                        has_media = True
    return ' '.join(full_text).strip(), has_media

def build_system_prompt(user_text, niche_id=None):
    core = load_core()
    if user_text.strip().upper().startswith('[СИСТЕМА]'):
        try:
            with open(SNAPSHOT_PATH, 'r', encoding='utf-8') as f: snap = f.read()
        except: snap = '[Слепок недоступен]'
        return f'{core}\n\n[СИСТЕМНЫЙ РЕЖИМ]\n{snap}\n\nОтветь кратко, по делу.'
    prompt = core
    if niche_id: prompt += load_niche_context(niche_id)
    return prompt

def call_provider_sync(messages, system_prompt, provider):
    payload_msgs = [{'role': 'system', 'content': system_prompt}] + messages
    payload = {'model': provider['model'], 'messages': payload_msgs, 'temperature': 0.4, 'max_tokens': 1500}
    try:
        resp = requests.post(provider['url'], json=payload, headers=provider['headers'], timeout=25, verify=provider['verify'])
        if resp.status_code == 200:
            data = resp.json()
            content = data.get('choices',[{}])[0].get('message',{}).get('content','')
            if content:
                logger.info(f'Provider {provider["name"]} OK')
                return content
        else:
            logger.warning(f'Provider {provider["name"]} -> {resp.status_code}')
    except Exception as e:
        logger.error(f'Provider {provider["name"]} error: {e}')
    return None

def call_with_fallback(messages, system_prompt, force_vision=False):
    targets = PROVIDERS
    if force_vision:
        targets = [p for p in PROVIDERS if p.get('vision')] + [p for p in PROVIDERS if not p.get('vision')]
    for p in targets:
        res = call_provider_sync(messages, system_prompt, p)
        if res: return res
    return '[ОШИБКА: Все провайдеры недоступны. Проверь ключи, сеть или Ollama.]'

def stream_generator(messages, system_prompt, force_vision=False):
    full = call_with_fallback(messages, system_prompt, force_vision)
    cid = f'chatcmpl-{uuid.uuid4().hex[:8]}'
    chunk = {'id':cid,'object':'chat.completion.chunk','created':int(time.time()),'model':'zinaida-router','choices':[{'index':0,'delta':{'content':full},'finish_reason':'stop'}]}
    yield f'data: {json.dumps(chunk)}\n\n'
    yield 'data: [DONE]\n\n'

@app.get('/health')
def health():
