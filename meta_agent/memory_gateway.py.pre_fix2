import requests, json, logging, os
from fastapi import FastAPI, Request, BackgroundTasks
from fastapi.responses import JSONResponse
from fastapi.middleware.cors import CORSMiddleware
import uvicorn
from state_manager import create_snapshot

logging.basicConfig(level=logging.INFO, format="%(asctime)s [GATEWAY] %(message)s")
logger = logging.getLogger(__name__)

app = FastAPI(title="Zinaida Memory Gateway")
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

CORE_URL = "http://localhost:8000/v1/chat/completions"
MEMORY_URL = "http://localhost:8505"
TASK_MASTER_PATH = "/opt/zinaida/dashboard/TASK_MASTER.md"
KB_PATH = "/opt/zinaida/sandbox/knowledge/provider_knowledge_base.md"

SYSTEM_INSTRUCTION = """🌐 ЯЗЫК: Все ответы, диалоги, отчёты и технические выводы → СТРОГО на русском языке. Код, JSON и технические идентификаторы → без перевода.


🤖 ПРОТОКОЛ КРОСС-АВТОНОМИИ И СТАТУСОВ:
1. Вы единый контур. Если один завис или не отвечает → второй диагностирует, перезапускает компонент через sandbox/execution_bridge и сообщает статус.
2. НИКОГДА не молчите. При получении задачи сразу отвечайте: [Григорий] Принял, анализирую... / [Зинаида] Контролирую, жду результат...
3. Если обработка занимает >10 сек → напишите промежуточный статус. Не заставляйте оператора ждать в тишине.
4. Все технические ответы, код, логи, планы → выводите открытым текстом. JSON-команды задач → СТРОГО одной строкой в самом конце.
5. При сбое провайдера/ядра → используйте log_reader, читайте документацию, переключайте маршруты в песочнице. Прод не трогать.
6. Взаимный ремонт: если видите, что напарник не ответил или вернул ошибку → берите задачу на себя, чините, отчитывайтесь.

📦 ОБНОВЛЕНИЕ ЗАДАЧ (СТРОГО):
В конце ответа добавь ОДНУ СТРОКУ JSON:
{"task_id": <число>, "status": "<executing|done|stuck>", "result": "<итог>"}
⛔ ЗАПРЕЩЕНО: markdown-обёртки для JSON, пустые блоки, текст после JSON.
"""

def build_system_context():
    parts = []
    try:
        if os.path.exists(TASK_MASTER_PATH):
            with open(TASK_MASTER_PATH, "r", encoding="utf-8") as f:
                parts.append(f"📖 TASK_MASTER.md:\n{f.read()[:1000]}")
    except Exception as e:
        logger.warning(f"TASK_MASTER read failed: {e}")
    try:
        if os.path.exists(KB_PATH):
            with open(KB_PATH, "r", encoding="utf-8") as f:
                parts.append(f"📚 KNOWLEDGE BASE:\n{f.read()[:1000]}")
    except Exception as e:
        logger.warning(f"KB read failed: {e}")
    try:
        tasks = []
        for st in ["planning", "executing", "stuck"]:
            r = requests.get(f"{MEMORY_URL}/memory/tasks?status={st}", timeout=3)
            if r.status_code == 200:
                tasks.extend(r.json().get("tasks", []))
        if tasks:
            lines = [f"- [{t['status'].upper()}] ID:{t['id']} | {t['title']}" for t in tasks[:5]]
            parts.append(f"📌 ЗАДАЧИ:\n" + "\n".join(lines))
    except Exception as e:
        logger.warning(f"Tasks fetch failed: {e}")
    if parts:
        return "📋 КОНТЕКСТ:\n" + "\n\n".join(parts) + "\n\n" + SYSTEM_INSTRUCTION
    return SYSTEM_INSTRUCTION

def parse_and_execute_commands(text: str) -> str:
    if not text: return text
    logger.info(f"RAW LLM OUTPUT: {text[:250]}")
    
    lines = text.split('\n')
    cleaned_lines = []
    
    for line in lines:
        stripped = line.strip()
        if stripped.startswith('{') and stripped.endswith('}'):
            try:
                cmd = json.loads(stripped)
                if isinstance(cmd, dict) and "task_id" in cmd and "status" in cmd:
                    task_id = cmd.get("task_id")
                    status = cmd.get("status")
                    result = cmd.get("result", "")
                    payload = {"status": status}
                    if result: payload["result"] = result
                    try:
                        r = requests.put(f"{MEMORY_URL}/memory/task/{task_id}", json=payload, timeout=5)
                        if r.status_code == 200:
                            logger.info(f"✅ TASK {task_id} UPDATED TO {status}")
                            if status == "done": create_snapshot(reason=f"task_{task_id}_done")
                    except Exception as e:
                        logger.warning(f"Task update failed: {e}")
                    continue  # Пропускаем строку с JSON-командой
            except: pass
        cleaned_lines.append(line)
        
    cleaned_text = '\n'.join(cleaned_lines).strip()
    
    # Fallback ТОЛЬКО если ответ абсолютно пустой
    if not cleaned_text:
        cleaned_text = "⏳ Запрос принят. Агенты обрабатывают. Ожидайте статус."
        
    return cleaned_text

def ingest_episode(role: str, content: str):
    try:
        requests.post(f"{MEMORY_URL}/memory/ingest", json={"role": role, "content": content}, timeout=3)
    except Exception as e:
        logger.warning(f"Ingest skipped: {e}")

def make_openai_response(content: str, model: str = "gateway-fallback"):
    return {
        "id": "chatcmpl-gateway",
        "object": "chat.completion",
        "created": int(os.popen("date +%s").read().strip()),
        "model": model,
        "choices": [{"index": 0, "message": {"role": "assistant", "content": content}, "finish_reason": "stop"}],
        "usage": {"prompt_tokens": 0, "completion_tokens": 0, "total_tokens": 0}
    }

@app.post("/v1/chat/completions")
async def gateway_chat(request: Request, background_tasks: BackgroundTasks):
    try:
        data = await request.json()
        messages = data.get("messages", [])
        if not messages: return JSONResponse({"error": "No messages"}, status_code=400)
        data["stream"] = False
        
        ctx = build_system_context()
        if ctx:
            has_sys = any(m.get("role") == "system" for m in messages)
            if has_sys:
                for m in messages:
                    if m.get("role") == "system":
                        m["content"] = f"{ctx}\n\n{m.get('content', '')}"
                        break
            else:
                messages.insert(0, {"role": "system", "content": ctx})
                
        payload = {**data, "messages": messages}
        try:
            resp = requests.post(CORE_URL, headers={"Content-Type": "application/json"}, json=payload, timeout=120)
            if resp.status_code != 200:
                return JSONResponse(make_openai_response("⚠️ System Error 502: Ядро не ответило. Запусти log_reader_tool.py."))
        except requests.exceptions.Timeout:
            return JSONResponse(make_openai_response("⏳ System Timeout: Запрос тяжёлый. Агенты работают, ожидайте."))
        except Exception as e:
            return JSONResponse(make_openai_response(f"⚠️ System Error: {str(e)[:100]}"))
            
        core_data = resp.json()
        assistant_text = core_data.get("choices", [{}])[0].get("message", {}).get("content", "")
        cleaned_text = parse_and_execute_commands(assistant_text)
        if cleaned_text != assistant_text:
            core_data["choices"][0]["message"]["content"] = cleaned_text
            
        background_tasks.add_task(ingest_episode, "user", messages[-1].get("content", ""))
        background_tasks.add_task(ingest_episode, "assistant", cleaned_text)
        return JSONResponse(core_data)
    except Exception as e:
        logger.error(f"Gateway fatal: {e}")
        return JSONResponse(make_openai_response(f"⚠️ Gateway Fatal: {str(e)[:100]}"))

if __name__ == "__main__":
    uvicorn.run(app, host="0.0.0.0", port=8001)
