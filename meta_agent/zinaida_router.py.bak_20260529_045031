import os, json, requests, time, sys, asyncio, uuid, logging
from fastapi import FastAPI, Request
from fastapi.responses import JSONResponse, StreamingResponse

logging.basicConfig(filename='/opt/zinaida/logs/zinaida_router.log', level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')
logger = logging.getLogger(__name__)
app = FastAPI()

def load_env():
    env_path = '/opt/zinaida/meta_agent/.env'
    if not os.path.exists(env_path): return {}
    env_vars = {}
    with open(env_path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip().replace('\r', '')
            if not line or line.startswith('#'): continue
            if line.startswith('export '): line = line[7:].strip()
            if '=' in line:
                k, v = line.split('=', 1)
                k, v = k.strip(), v.strip().strip('"').strip("'")
                if k and v:
                    env_vars[k] = v
                    os.environ[k] = v
    return env_vars

ENV = load_env()
