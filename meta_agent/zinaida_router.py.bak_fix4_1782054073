@app.post("/v1/chat/completions")
async def chat(request: Request):
    try:
        data = await request.json()
        messages = data.get('messages', [])
        if not messages:
            return JSONResponse(status_code=400, content={"error": "messages required"})
        extracted_text, has_media = extract_text_and_media(messages)
        sys_prompt = build_system_prompt(extracted_text)

        stream = data.get('stream', False)
        # === SMM DELEGATION START ===
        _smm_check = json.dumps(messages[-1]) if messages else ""
        try: logger.info(f"SMM_TRIGGER_CHECK: {_smm_check[:100]}")
        except Exception: pass
        if "[PROJECT: smm]" in _smm_check or "smm" in _smm_check.lower():
            try: logger.info("SMM_TRIGGER_FIRED")
            except Exception: pass
            task_payload = {"task_id": str(uuid.uuid4()), "correlation_id": str(uuid.uuid4()), "phase": "research", "payload": {"user_input": _smm_check}}
            task_json = json.dumps(task_payload)
            loop = asyncio.get_running_loop()
            try:
                result = await loop.run_in_executor(None, lambda: subprocess.run(
                    ['python3', '/opt/zinaida/sandbox/smm_factory/smm_coordinator.py'],
                    input=task_json, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True, timeout=300, start_new_session=True
                ))
                response_data = json.loads(result.stdout)
            except subprocess.TimeoutExpired as e:
                try: os.killpg(os.getpgid(e.pid), signal.SIGKILL)
                except Exception: pass
                response_data = {"status": "error", "error": "SMM_CHAIN_TIMEOUT", "ts": "now"}
            except Exception as sub_e:
                response_data = {"status": "error", "error": f"SMM_CHAIN_ERROR: {str(sub_e)}", "ts": "now"}
            return JSONResponse(content=response_data)
        # === SMM DELEGATION END ===

        if stream:
            return StreamingResponse(
                stream_generator(messages, sys_prompt, force_vision=has_media),
                media_type="text/event-stream",
                headers={"Cache-Control": "no-cache", "Connection": "keep-alive"}
            )

        reply = call_with_smart_routing(messages, sys_prompt, force_vision=has_media)
        return {"choices": [{"message": {"role": "assistant", "content": reply}}]}
    except Exception as e:
        logger.error(f"ROUTER ERROR: {e}")
        return JSONResponse(status_code=500, content={"error": str(e)})

