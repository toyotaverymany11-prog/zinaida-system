def load_core():
    global _core_cache
    try:
        mtime = os.path.getmtime(CORE_PATH)
        if mtime != _core_cache['mtime']:
            with open(CORE_PATH, 'r', encoding='utf-8') as f:
                _core_cache['content'] = f.read()
            _core_cache['mtime'] = mtime
        return _core_cache['content']
    except Exception as e:
        logger.error(f"CORE load fail: {e}")
        return _core_cache['content'] or "Ты — Зинаида, инженер-архитектор. Говори коротко, по делу."

def load_env():
    env_path = '/opt/zinaida/meta_agent/.env'
    if not os.path.exists(env_path): return {}
    env_vars = {}
    with open(env_path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip().replace('\r', '')
            if not line or line.startswith('#'): continue
            if line.startswith('export '): line = line[7:].strip()
            key, sep, value = line.partition('=')
            if sep:
                env_vars[key.strip()] = value.strip().strip('"').strip("'")
    return env_vars

