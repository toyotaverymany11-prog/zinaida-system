def truncate_context(messages, system_prompt, max_chars=9000):
    """Приоритетный бюджетер контекста.
    Неприкосновенны: Слой 0 (ДНК, ~4000 символов в начале system_prompt) и Слой 1 (Стиль).
    При перегрузке: обрезает историю сообщений, затем RAG-слои в системном промпте.
    """
    total_len = len(system_prompt) + sum(len(str(m.get('content', ''))) for m in messages)
    if total_len <= max_chars:
        return messages, system_prompt
    
    # Шаг 1: Обрезаем историю сообщений до последних 3 (user/assistant)
    safe_messages = messages[-3:] if len(messages) > 3 else messages
    total_len = len(system_prompt) + sum(len(str(m.get('content', ''))) for m in safe_messages)
    
    # Шаг 2: Если всё ещё перегрузка — обрезаем системный промпт
    if total_len > max_chars:
        # Сохраняем первые 4000 символов (ДНК + Стиль)
        safe_prompt = system_prompt[:4000]
        safe_prompt += "\n\n[КОНТЕКСТ УСЕЧЁН ДЛЯ БЕЗОПАСНОЙ ДОСТАВКИ ПРОВАЙДЕРУ]"
    else:
        safe_prompt = system_prompt
    
    return safe_messages, safe_prompt

