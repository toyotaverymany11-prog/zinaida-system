import os, json, requests, time, sys, asyncio, uuid
from fastapi import FastAPI, Request
from fastapi.responses import StreamingResponse, JSONResponse
from typing import List, Dict, Any

app = FastAPI()

def load_env():
    env_path = '/opt/zinaida/meta_agent/.env'
    if not os.path.exists(env_path): return {}
    env_vars = {}
    with open(env_path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip().replace('\r', '')
            if not line or line.startswith('#'): continue
            if line.startswith('export '): line = line[7:].strip()
            if '=' in line:
                k, v = line.split('=', 1)
                k, v = k.strip(), v.strip().strip('"').strip("'")
                if k and v: env_vars[k] = v
    return env_vars

ENV = load_env()

PROVIDERS = []
if ENV.get('ZHIPU_API_KEY'):
    PROVIDERS.append({'name': 'zhipu', 'url': 'https://open.bigmodel.cn/api/paas/v4/chat/completions', 'model': 'glm-4-flash', 'headers': {'Authorization': f"Bearer {ENV['ZHIPU_API_KEY']}", 'Content-Type': 'application/json'}})
if ENV.get('GITHUB_TOKEN'):
    PROVIDERS.append({'name': 'github', 'url': 'https://models.inference.ai.azure.com/chat/completions', 'model': 'gpt-4o-mini', 'headers': {'Authorization': f"Bearer {ENV['GITHUB_TOKEN']}", 'Content-Type': 'application/json'}, 'vision': True})
or_key = ENV.get('OPENROUTER_API_KEY') or ENV.get('OPENROUTER_KEY')
if or_key:
    PROVIDERS.append({'name': 'openrouter', 'url': 'https://openrouter.ai/api/v1/chat/completions', 'model': 'google/gemma-3-12b-it:free', 'headers': {'Authorization': f"Bearer {or_key}", 'Content-Type': 'application/json', 'HTTP-Referer': 'http://localhost:8787', 'X-Title': 'Hermes-Zinaida'}, 'vision': True})
if ENV.get('OLLAMA_MODEL'):
    PROVIDERS.append({'name': 'ollama', 'url': 'http://127.0.0.1:11434/v1/chat/completions', 'model': ENV.get('OLLAMA_MODEL', 'gemma3:4b'), 'headers': {'Content-Type': 'application/json'}, 'vision': True})

def load_core():
    try:
        with open('/opt/zinaida/memory/knowledge/CORE.md', 'r', encoding='utf-8') as f:
            return f.read()
    except Exception as e:
        print(f"ERR: CORE load fail: {e}")
        return "Ты — Зинаида, инженер-архитектор. Говори коротко, по делу."

def extract_text_and_media(messages: List[Dict[str, Any]]) -> tuple[str, bool]:
    full_text = []
    has_media = False
    for msg in messages:
        content = msg.get('content', '')
        if isinstance(content, str):
            full_text.append(content)
        elif isinstance(content, list):
            for part in content:
                if isinstance(part, dict):
                    ptype = part.get('type', '')
                    if ptype == 'text':
                        full_text.append(part.get('text', ''))
                    elif ptype in ('image_url', 'file', 'image'):
                        has_media = True
    return ' '.join(full_text).strip(), has_media

def build_system_prompt(user_text: str, niche_id: str = None):
    core = load_core()
    if user_text.strip().upper().startswith('[СИСТЕМА]'):
        try:
            with open('/opt/zinaida/memory/SYSTEM_SNAPSHOT.md', 'r', encoding='utf-8') as f:
                snap = f.read()
        except: snap = '[Слепок недоступен]'
        return f"{core}\n\n[СИСТЕМНЫЙ РЕЖИМ]\n{snap}\n\nОтветь кратко."
    return core

def call_provider_sync(messages: List[Dict], system_prompt: str, provider: Dict):
    headers = provider['headers']
    payload = {
        'model': provider['model'],
        'messages': [{'role': 'system', 'content': system_prompt}] + messages,
        'temperature': 0.7
    }
    try:
        resp = requests.post(provider['url'], json=payload, headers=headers, timeout=25)
        if resp.status_code == 200:
            data = resp.json()
            content = data.get('choices', [{}])[0].get('message', {}).get('content', '')
            if content:
                print(f"PROVIDER {provider['name']} OK")
                return content
        else:
            print(f"PROVIDER {provider['name']} -> {resp.status_code}: {resp.text}")
    except Exception as e:
        print(f"PROVIDER {provider['name']} ERROR: {e}")
    return None

def call_with_fallback(messages: List[Dict], system_prompt: str, force_vision: bool = False):
    targets = PROVIDERS
    if force_vision:
        targets = [p for p in PROVIDERS if p.get('vision')] + [p for p in PROVIDERS if not p.get('vision')]
    for p in targets:
        res = call_provider_sync(messages, system_prompt, p)
        if res: return res
    return "[ОШИБКА: Все провайдеры недоступны. Проверь ключи или сеть.]"

def stream_generator(messages: List[Dict], system_prompt: str, force_vision: bool = False):
    full = call_with_fallback(messages, system_prompt, force_vision)
    cid = f"chatcmpl-{uuid.uuid4().hex[:8]}"
    chunk = {'id': cid, 'object': 'chat.completion.chunk', 'created': int(time.time()), 'model': 'fallback', 'choices': [{'index': 0, 'delta': {'content': full}, 'finish_reason': 'stop'}]}
    yield f"data: {json.dumps(chunk)}\n\n"
    yield "data: [DONE]\n\n"

@app.get("/health")
def health():
    return {"status": "ok", "router": "zinaida_fallback_v4_vision", "providers": [p['name'] for p in PROVIDERS]}

@app.post("/v1/chat/completions")
async def chat(request: Request):
    try:
        data = await request.json()
        messages = data.get('messages', [])
        if not messages:
            return JSONResponse(status_code=400, content={"error": "messages required"})

        extracted_text, has_media = extract_text_and_media(messages)
        stream = data.get('stream', False)
        sys_prompt = build_system_prompt(extracted_text)

        if stream:
            return StreamingResponse(stream_generator(messages, sys_prompt, force_vision=has_media), media_type="text/event-stream")
        reply = call_with_fallback(messages, sys_prompt, force_vision=has_media)
        return {"choices": [{"message": {"role": "assistant", "content": reply}}]}
    except Exception as e:
        print(f"ROUTER ERROR: {e}")
        return JSONResponse(status_code=500, content={"error": str(e)})

