def analyze_intent(text: str) -> str:
    """Определяет тип задачи по тексту."""
    text_lower = text.lower()
    if any(word in text_lower for word in ["код", "исправь", "напиши", "fix", "script", "скрипт", "функцию", "функция"]):
        return "[КОД]"
    if any(word in text_lower for word in ["пост", "вк", "vk", "контент", "текст", "публикация", "сторителлинг", "лера"]):
        return "[КОНТЕНТ]"
    if any(word in text_lower for word in ["статус", "что с", "проверь", "система", "бот", "запущен", "работает"]):
        return "[СИСТЕМА]"
    if any(word in text_lower for word in ["тест", "проверка", "бриф", "запусти"]):
        return "[ТЕСТ]"
    if any(word in text_lower for word in ["синхрониз", "память", "обнови", "обновление"]):
        return "[СИНХРОНИЗАЦИЯ]"
    return None

def load_file(path):
    try:
        with open(path, 'r', encoding='utf-8') as f: return f.read()
    except Exception: return ""

def run_tool_sync(tool_key):
    cmd = TOOL_WHITELIST.get(tool_key.lower().strip())
    if not cmd: return "[ИНСТРУМЕНТ НЕ НАЙДЕН В БЕЛОМ СПИСКЕ]"
    try:
        res = subprocess.run(cmd, capture_output=True, text=True, timeout=60, cwd="/opt/zinaida/sandbox")
        return res.stdout[:2500] if res.returncode == 0 else f"[ОШИБКА ВЫПОЛНЕНИЯ]: {res.stderr[:500]}"
    except Exception as e:
        return f"[СБОЙ ИНСТРУМЕНТА]: {str(e)}"

def run_delegation(intent_trigger: str, original_text: str):
    """Вызов делегатора для внешних агентов."""
    try:
        import importlib.util
        spec = importlib.util.spec_from_file_location("delegator", DELEGATOR_PATH)
        delegator_module = importlib.util.module_from_spec(spec)
        spec.loader.exec_module(delegator_module)
        result = delegator_module.delegate_task(intent_trigger, {"original_text": original_text})
        return json.dumps(result, ensure_ascii=False)
    except Exception as e:
        return f"[ОШИБКА ДЕЛЕГАТОРА]: {str(e)}"

def build_system_prompt(user_text, niche_id=None, tool_result=None, delegation_result=None):
    core = load_file(CORE_PATH) or "Ты — Зинаида, руководитель маркетингового агентства. Говори в женском роде."

    # Приоритет: делегация > инструмент > системный > стандартный
    if delegation_result:
        return f"{core}\n\n[РЕЗУЛЬТАТ ДЕЛЕГАЦИИ]\n{delegation_result}\n\nОформи результат кратко, профессионально, в женском роде. Если были ошибки — предложи решение."
    
    if user_text.strip().upper().startswith("[СИСТЕМА]"):
        snapshot = load_file(SNAPSHOT_PATH) or "[Слепок системы недоступен]"
        return f"{core}\n\n[СИСТЕМНЫЙ РЕЖИМ]\nТекущее состояние сервера и компонентов:\n{snapshot}\n\nОтветь кратко, по делу, используя только факты из слепка. Не выдумывай статусы."
    
    if tool_result:
        return f"{core}\n\n[РЕЗУЛЬТАТ ИНСТРУМЕНТА]\n{tool_result}\n\nОформи результат кратко, профессионально, в женском роде. Если есть ошибки — предложи решение."
    
    prompt = core
    if niche_id:
        brief = load_file(os.path.join(NICHES_DIR, niche_id, "brief.md"))
        tone = load_file(os.path.join(NICHES_DIR, niche_id, "tone.md"))
        if brief: prompt += f"\n\n[КОНТЕКСТ НИШИ]\n{brief}"
        if tone: prompt += f"\n\n[СТИЛЬ И ОГРАНИЧЕНИЯ]\n{tone}"
    return prompt

def call_provider(messages, system_prompt):
    payload_msgs = [{"role": "system", "content": system_prompt}] + messages
    for p in PROVIDERS:
        if not p["key"]: continue
        try:
            headers = {"Authorization": f"Bearer {p['key']}", "Content-Type": "application/json"}
            if p["name"] == "openrouter": headers["HTTP-Referer"] = "https://zinaida.local"
            payload = {"model": p["model"], "messages": payload_msgs, "temperature": 0.4, "max_tokens": 1500}
            resp = requests.post(p["url"], json=payload, headers=headers, timeout=25)
            if resp.status_code == 200:
                data = resp.json()
                content = data.get("choices", [{}])[0].get("message", {}).get("content", "")
                if content: return content
        except Exception:
            continue
    return "[ОШИБКА: Все провайдеры недоступны. Проверь ключи и сеть.]"

@app.get("/health")
def health():
    return {"status":"ok","router":"zinaida_with_provider_fallback_v1"}

@app.post("/v1/chat/completions")
async def chat(request: Request):
    try:
        data = await request.json()
        messages = data.get("messages", [])
        user_text = messages[-1].get("content", "") if messages else ""
        niche_id = data.get("niche_id") or request.headers.get("x-niche-id")
        
        # Автоматический анализ текста на предмет задачи
        intent = analyze_intent(user_text)
        
        # Обработка делегации (код, контент, etc.)
        delegation_result = None
        if intent and intent in ["[КОД]", "[КОНТЕНТ]"]:
            delegation_result = await asyncio.to_thread(run_delegation, intent, user_text)
        
        # Обработка инструментов ([ТЕСТ], [СИНХРОНИЗАЦИЯ])
        tool_result = None
        lower_text = user_text.strip().lower()
        if lower_text.startswith("[тест]"):
            tool_result = await asyncio.to_thread(run_tool_sync, "тест")
        elif lower_text.startswith("[синхронизация]"):
            tool_result = await asyncio.to_thread(run_tool_sync, "синхронизация")

        system_prompt = build_system_prompt(user_text, niche_id, tool_result, delegation_result)
        reply = call_provider(messages, system_prompt)
        
        return JSONResponse({
            "choices": [{"message": {"role": "assistant", "content": reply}}],
            "model": "zinaida-router",
            "usage": {"total_tokens": 0}
        })
    except Exception as e:
        return JSONResponse({"error": str(e)}, status_code=500)

