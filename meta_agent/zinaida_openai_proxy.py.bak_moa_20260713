def truncate_messages(messages, max_keep=30):
    """Оставляем системные + последние max_keep реплик. Старые сообщения сжимаются в summary."""
    if len(messages) <= max_keep + 2:
        return messages
    system_msgs = [m for m in messages if m.get("role") == "system"]
    non_system = [m for m in messages if m.get("role") != "system"]
    
    # Если слишком много сообщений - делаем summary старых
    if len(non_system) > max_keep:
        old_msgs = non_system[:-max_keep]
        recent = non_system[-max_keep:]
        # Сжимаем старые в одно сообщение
        old_summary_parts = []
        for m in old_msgs[-6:]:  # последние 6 из старых для контекста
            role = m.get("role", "?")
            content = (m.get("content") or "")[:200]
            if content:
                old_summary_parts.append(f"[{role}]: {content}")
        if old_summary_parts:
            summary_text = "[СЖАТАЯ ИСТОРИЯ (" + str(len(old_msgs)) + " сообщений)]n" + "n".join(old_summary_parts)
            system_msgs.append({"role": "system", "content": summary_text})
    else:
        recent = non_system
    
    while recent and recent[0].get("role") != "user":
        recent.pop(0)
    if not recent:
        recent = non_system[-max_keep:]
    return system_msgs + recent

def _truncate_text(text, limit):
    if not isinstance(text, str) or len(text) <= limit:
        return text
    head = int(limit * 0.6)
    tail = max(limit - head - 60, 200)
    cut = len(text) - head - tail
    return text[:head] + f"nn...[обрезано {cut} символов]...nn" + text[-tail:]

def _content_to_str(c) -> str:
    """Превращает content (строка, список, None) в строку.
    Исправляет ошибку 'list' object has no attribute 'strip' при мультимодальных запросах."""
    if c is None:
        return ""
    if isinstance(c, str):
        return c
    if isinstance(c, list):
        # Мультимодальный контент: собираем текст из частей
        parts = []
        for part in c:
            if isinstance(part, dict) and part.get("type") == "text":
                parts.append(part.get("text", ""))
        return " ".join(parts) if parts else json.dumps(c, ensure_ascii=False)
    return str(c)


def shrink_messages(messages, max_msg=MAX_MSG_CHARS, max_total=MAX_TOTAL_CHARS):
    out = []
    for m in messages:
        m = dict(m)
        c = m.get("content")
        # Принудительно конвертируем content в строку
        m["content"] = _content_to_str(c)
        if m.get("role") != "system":
            m["content"] = _truncate_text(m["content"], max_msg)
        out.append(m)

    def total(msgs):
        return sum(len(x.get("content") or "") for x in msgs if isinstance(x.get("content"), str))

    limit = max_msg
    while total(out) > max_total and limit > 600:
        limit = int(limit * 0.6)
        for m in out:
            if isinstance(m.get("content"), str) and m.get("role") != "system":
                m["content"] = _truncate_text(m["content"], limit)
    if total(out) > max_total:
        sys_limit = max(int(max_total * 0.5), 3000)
        for m in out:
            if isinstance(m.get("content"), str) and m.get("role") == "system":
                m["content"] = _truncate_text(m["content"], sys_limit)
    return out

def sanitize_payload(payload):
    return {k: v for k, v in payload.items() if k in ALLOWED_KEYS}

