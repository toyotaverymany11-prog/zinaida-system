def _log_cost(model: str, provider_name: str, prompt_tokens: int, completion_tokens: int):
    """Записывает стоимость запроса в cost_log.json."""
    try:
        pricing = MODEL_PRICING.get(model, {"input": 0, "output": 0})
        cost_usd = (prompt_tokens * pricing["input"] + completion_tokens * pricing["output"]) / 1_000_000
        entry = {
            "timestamp": time.strftime("%Y-%m-%dT%H:%M:%S"),
            "provider": provider_name,
            "model": model,
            "prompt_tokens": prompt_tokens,
            "completion_tokens": completion_tokens,
            "cost_usd": round(cost_usd, 6),
        }
        COST_LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
        # Читаем существующий лог
        entries = []
        if COST_LOG_PATH.exists():
            try:
                with open(COST_LOG_PATH, "r") as f:
                    entries = json.load(f)
            except Exception:
                entries = []
        entries.append(entry)
        # Держим последние 10000 записей
        if len(entries) > 10000:
            entries = entries[-10000:]
        with open(COST_LOG_PATH, "w") as f:
            json.dump(entries, f, ensure_ascii=False, indent=1)
        if cost_usd > 0:
            logger.info("COST: %s/%s - $%.6f (%d+%d tok)", provider_name, model, cost_usd, prompt_tokens, completion_tokens)
    except Exception as e:
        logger.warning("Cost logging failed: %s", e)

