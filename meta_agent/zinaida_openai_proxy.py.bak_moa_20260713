def _status_of(exc):
    resp = getattr(exc, "response", None)
    return resp.status_code if resp is not None else None

async def _post_once(name, key, data, timeout, max_msg, max_total):
    p = PROVIDERS[name]
    headers, work = await prepare_payload_and_headers(name, key, data, max_msg, max_total)
    async with httpx.AsyncClient(verify=False,
                                 timeout=httpx.Timeout(timeout, read=timeout, connect=CONNECT_TIMEOUT)) as client:
        resp = await client.post(p["url"], headers=headers, json=work)
        resp.raise_for_status()
        result = resp.json()
        # Логируем стоимость
        usage = result.get("usage", {})
        if usage:
            _log_cost(
                model=result.get("model", work.get("model", "")),
                provider_name=name,
                prompt_tokens=usage.get("prompt_tokens", 0),
                completion_tokens=usage.get("completion_tokens", 0),
            )
        return result

async def try_provider(name, data, timeout) -> Optional[dict]:
    p = PROVIDERS[name]
    keys = p["keys"] if p["kind"] != "gigachat" else ["oauth"]
    t0 = time.time()
    for ki, key in enumerate(keys):
        for attempt in range(3):  # 3 попытки с backoff
            mm = MAX_MSG_CHARS if attempt == 0 else MAX_MSG_CHARS // 2
            mt = p.get("max_total", MAX_TOTAL_CHARS) if attempt == 0 else p.get("max_total", MAX_TOTAL_CHARS) // 2
            try:
                result = await _post_once(name, key, data, timeout, mm, mt)
                latency = int((time.time() - t0) * 1000)
                _mark_alive(name, latency)
                logger.info("OK <- %s (key#%d, attempt %d, %d ms)", name, ki + 1, attempt + 1, latency)
                return result
            except httpx.HTTPStatusError as e:
                code = _status_of(e)
                logger.warning("FAIL <- %s key#%d HTTP %s (attempt %d)", name, ki + 1, code, attempt + 1)
                if code == 401 and name == "gigachat":
                    await get_gigachat_token(force=True)
                    continue
                if code in (401, 403):
                    break
                if code == 429:
                    # Rate limit - жди с backoff и ретрай
                    wait = 1.0 * (2 ** attempt)  # 1s, 2s, 4s
                    logger.info("RETRY <- %s key#%d 429 - жду %.1fs...", name, ki + 1, wait)
                    await asyncio.sleep(wait)
                    continue
                if code in (500, 502, 503, 504):
                    # Server error - жди и ретрай
                    wait = 0.5 * (2 ** attempt)  # 0.5s, 1s, 2s
                    logger.info("RETRY <- %s key#%d HTTP %d - жду %.1fs...", name, ki + 1, code, wait)
                    await asyncio.sleep(wait)
                    continue
                if code in (400, 413, 422):
                    if attempt == 0:
                        continue
                    break
                break
            except (httpx.ConnectError, httpx.ConnectTimeout, httpx.ReadTimeout) as e:
                logger.warning("FAIL <- %s key#%d network: %s (attempt %d)", name, ki + 1, type(e).__name__, attempt + 1)
                # Network error - жди и ретрай (кроме последней попытки)
                if attempt < 2:
                    wait = 0.5 * (2 ** attempt)
                    logger.info("RETRY <- %s key#%d network - жду %.1fs...", name, ki + 1, wait)
                    await asyncio.sleep(wait)
                    continue
                break
            except Exception as e:
                logger.warning("FAIL <- %s key#%d error: %s (attempt %d)", name, ki + 1, e, attempt + 1)
                break
    _mark_dead(name, f"all keys failed")
    return None

# ============================================================================
# 11. ОЧИСТКА REASONING ИЗ ОТВЕТОВ МОДЕЛИ
# ============================================================================
def _strip_reasoning_from_chunk(chunk: str):
    """Удаляет reasoning_content/reasoning из SSE-чанка.
    Если после удаления в дельте пусто — возвращает None (пропускаем чанк)."""
    if chunk == "data: [DONE]":
        return chunk
    try:
        data = json.loads(chunk[6:])
        for ch in data.get("choices", []):
            delta = ch.get("delta", {})
            removed = delta.pop("reasoning_content", None) or delta.pop("reasoning", None)
            if removed is not None and not delta.get("content"):
                return None  # чанк только с reasoning — выкидываем
        data = _sanitize_chunk_content(data)
        return "data: " + json.dumps(data, ensure_ascii=False)
    except (json.JSONDecodeError, KeyError, IndexError):
        return chunk


def _sanitize_chunk_content(data: dict) -> dict:
    """Заменяет запрещённые символы в контенте чанка.
    Длинные тире, средние тире, многоточия, жирные точки."""
    for ch in data.get("choices", []):
        delta = ch.get("delta", {})
        content = delta.get("content")
        if content:
            content = content.replace("\u2014", "-").replace("\u2013", "-")
            content = content.replace("\u2026", ".")
            for bullet in ["\u2022", "\u25CF", "\u25E6"]:
                content = content.replace(bullet, "-")
            delta["content"] = content
    return data

def _clean_reasoning_generator(agen):
    """Оборачивает асинхронный генератор SSE-чанков, вырезая reasoning."""
    async def wrapper(r, c):
        try:
            async for chunk in agen(r, c):
                cleaned = _strip_reasoning_from_chunk(chunk)
                if cleaned is not None:
                    yield cleaned
        except Exception as e:
            logger.warning("REASONING-FILTER error: %s", e)
    return wrapper

def _strip_reasoning_from_response(result: dict) -> dict:
    """Удаляет reasoning из не-streaming ответа модели + чистит пунктуацию."""
    for ch in result.get("choices", []):
        msg = ch.get("message", {})
        msg.pop("reasoning", None)
        msg.pop("reasoning_content", None)
        content = msg.get("content")
        if content:
            content = content.replace("\u2014", "-").replace("\u2013", "-")
            content = content.replace("\u2026", ".")
            for bullet in ["\u2022", "\u25CF", "\u25E6"]:
                content = content.replace(bullet, "-")
            msg["content"] = content
    return result

# ============================================================================
# 12. GRACEFUL FALLBACK
# ============================================================================
def _degraded_text() -> str:
    dead = [n for n in PROVIDERS if not _is_available(n)]
    alive = [n for n in PROVIDERS if _is_available(n)]
    if dead:
        # Мёртвые: без денег/ключа. Живые: перегружены прямо сейчас.
        dead_str = ", ".join(dead)
        alive_str = ", ".join(alive[:3]) if alive else "нет"
        return (f"Провайдеры временно недоступны. Мёртвы: {dead_str}. "
                f"Живы (но не ответили): {alive_str}. Автовосстановление запущено - повтори запрос.")
    return "Провайдеры сейчас перегружены. Повтори запрос через минуту."

def _fallback_response():
    return {
        "id": "chatcmpl-fallback", "object": "chat.completion",
        "created": int(time.time()), "model": "Zinaida-Router",
        "choices": [{"index": 0,
                     "message": {"role": "assistant", "content": _degraded_text()},
                     "finish_reason": "stop"}],
        "usage": {"prompt_tokens": 0, "completion_tokens": 0, "total_tokens": 0},
    }

