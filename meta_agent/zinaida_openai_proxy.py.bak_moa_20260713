@app.post("/v1/chat/completions")
async def chat(request: Request):
    try:
        data = await request.json()
        is_stream = data.get("stream", False)
        timeout = float(data.get("timeout", GEN_READ_TIMEOUT))
        msgs = data.get("messages", [])
        
        # Выбор цепочки fallback по типу запроса
        if is_creative_request(msgs):
            base_order = ORDER_CREATIVE
        elif is_code_request(msgs):
            base_order = ORDER_CODE
        else:
            base_order = ORDER_CHAT
        
        # Если клиент явно запросил конкретную модель DeepSeek
        requested_model = data.get("model", "")
        if "deepseek-reasoner" in requested_model:
            base_order = ["deepseek_pro"] + [x for x in base_order if x != "deepseek_pro"]
        elif "deepseek-chat" in requested_model:
            base_order = ["deepseek_flash"] + [x for x in base_order if x != "deepseek_flash"]
            
        order = [n for n in base_order if _is_available(n)] + \
                [n for n in base_order if not _is_available(n) and PROVIDERS[n]["keys"]]

        if is_stream:
            # --- RACE-СТРИМИНГ: ТОЛЬКО БЕСПЛАТНЫЕ ПРОВАЙДЕРЫ ---
            alive_order = [n for n in order if _is_available(n)]
            if not alive_order:
                alive_order = order  # если все формально мертвы - пробуем всех
            
            # Гонка только среди бесплатных. DeepSeek — не в гонке, только как fallback
            free_race = [n for n in alive_order if n in FREE_PROVIDERS]
            if not free_race:
                free_race = alive_order[:1]  # если бесплатных нет — хотя бы одного
            
            race_pool = free_race[:2] if len(free_race) >= 2 else free_race[:1]
            
            # Флаг - первый ответивший уже отдаёт результат
            _race_winner = None
            
            async def _stream_worker(name: str) -> Optional[tuple]:
                """Пытаемся застримить от провайдера. Возвращает (StreamingResponse, None) или (None, error)."""
                global _race_winner
                p = PROVIDERS[name]
                keys = p["keys"] if p["kind"] != "gigachat" else ["oauth"]
                for ki, key in enumerate(keys):
                    for attempt in range(2):
                        mm = MAX_MSG_CHARS if attempt == 0 else MAX_MSG_CHARS // 2
                        mt = p.get("max_total", MAX_TOTAL_CHARS) if attempt == 0 else p.get("max_total", MAX_TOTAL_CHARS) // 2
                        t0 = time.time()
                        try:
                            headers, work = await prepare_payload_and_headers(name, key, data, mm, mt)
                            client = httpx.AsyncClient(verify=False,
                                        timeout=httpx.Timeout(timeout, read=timeout, connect=CONNECT_TIMEOUT))
                            resp = await client.send(
                                client.build_request("POST", p["url"], headers=headers, json=work),
                                stream=True)
                            if resp.status_code >= 400:
                                sc = resp.status_code
                                await resp.aclose(); await client.aclose()
                                logger.warning("FAIL(stream) <- %s key#%d HTTP %s (attempt %d, %.1fs)",
                                               name, ki + 1, sc, attempt + 1, time.time() - t0)
                                if sc == 401 and name == "gigachat":
                                    await get_gigachat_token(force=True)
                                if sc in (400, 413, 422) and attempt == 0:
                                    continue
                                break
                            _mark_alive(name)
                            logger.info("OK(stream) <- %s key#%d (%.1fs)", name, ki + 1, time.time() - t0)
                            
                            # Этот воркер выиграл гонку - отдаём стрим
                            async def stream_gen(r, c, n):
                                try:
                                    async for chunk in r.aiter_lines():
                                        if chunk:
                                            yield f"{chunk}nn"
                                except Exception as e:
                                    logger.warning("STREAM BROKEN: %s порвался mid-flight: %s", n, e)
                                    # Если стрим порвался - это катастрофа, но хотя бы не падаем
                                finally:
                                    await r.aclose(); await c.aclose()
                            return (name, client, resp)  # сигнал "я выиграл"
                        except Exception as e:
                            logger.warning("FAIL(stream) <- %s key#%d %s (attempt %d, %.1fs)",
                                           name, ki + 1, type(e).__name__, attempt + 1, time.time() - t0)
                            break
                logger.warning("SKIP(stream) <- %s все попытки исчерпаны", name)
                return None
            
            # Запускаем гонку
            tasks = {}
            for n in race_pool:
                tasks[n] = asyncio.ensure_future(_stream_worker(n))
            
            winner = None
            # Ждём первого успешного или всех неудач
            while tasks:
                done, pending = await asyncio.wait(tasks.values(), return_when=asyncio.FIRST_COMPLETED)
                for d in done:
                    result = d.result()
                    if result is not None:
                        winner_name, winner_client, winner_resp = result
                        if winner is None:
                            winner = (winner_name, winner_client, winner_resp)
                            # Отменяем остальных, кто ещё бежит
                            for pname, ptask in list(tasks.items()):
                                if pname != winner_name and not ptask.done():
                                    ptask.cancel()
                    tasks = {n: t for n, t in tasks.items() if not t.done()}
                if winner is not None:
                    break
            
            if winner is not None:
                name, client, resp = winner
                logger.info("RACE WINNER: %s - отдаём стрим", name)
                async def winner_stream(r, c):
                    try:
                        async for chunk in r.aiter_lines():
                            if chunk:
                                cleaned = _strip_reasoning_from_chunk(chunk)
                                if cleaned is not None:
                                    yield f"{cleaned}nn"
                    except Exception as e:
                        logger.warning("STREAM BROKEN mid-flight от %s: %s", name, e)
                    finally:
                        await r.aclose(); await c.aclose()
                return StreamingResponse(winner_stream(resp, client), media_type="text/event-stream")
            
            # Все провайдеры из race упали - пробуем остальных (per-provider, не race)
            logger.warning("RACE: оба провала (%s), пробую остальных по очереди", ", ".join(race_pool))
            for name in [n for n in order if n not in race_pool]:
                result = await _stream_worker(name)
                if result is not None:
                    n2, c2, r2 = result
                    async def fallback_stream(r, c):
                        try:
                            async for chunk in r.aiter_lines():
                                if chunk:
                                    cleaned = _strip_reasoning_from_chunk(chunk)
                                    if cleaned is not None:
                                        yield f"{cleaned}nn"
                        finally:
                            await r.aclose(); await c.aclose()
                    return StreamingResponse(fallback_stream(r2, c2), media_type="text/event-stream")
            
            # Fallback - ничего не сработало
            logger.error("ВСЕ ПРОВАЙДЕРЫ УПАЛИ (stream) -> graceful fallback")
            async def fb_gen():
                payload = {"id": "chatcmpl-fallback", "object": "chat.completion.chunk",
                           "created": int(time.time()), "model": "Zinaida-Router",
                           "choices": [{"index": 0, "delta": {"role": "assistant", "content": _degraded_text()},
                                        "finish_reason": None}]}
                yield f"data: {json.dumps(payload, ensure_ascii=False)}nn"
                payload["choices"][0]["delta"] = {}
                payload["choices"][0]["finish_reason"] = "stop"
                yield f"data: {json.dumps(payload, ensure_ascii=False)}nn"
                yield "data: [DONE]nn"
            return StreamingResponse(fb_gen(), media_type="text/event-stream")

        # НЕ-стрим путь
        for name in order:
            result = await try_provider(name, data, timeout)
            if result is not None:
                _strip_reasoning_from_response(result)
                return JSONResponse(result)
        logger.error("ВСЕ ПРОВАЙДЕРЫ УПАЛИ -> graceful fallback")
        return JSONResponse(_fallback_response())
    except Exception as e:
        logger.error("Router crash: %s", e)
        return JSONResponse({"error": str(e)}, status_code=500)

