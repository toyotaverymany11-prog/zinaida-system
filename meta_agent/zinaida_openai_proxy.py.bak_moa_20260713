    now = time.time()
    providers = {}
    for name, p in PROVIDERS.items():
        st = _state[name]
        providers[name] = {
            "available": _is_available(name),
            "keys": len(p["keys"]),
            "model": p["model"],
            "paid": p.get("paid", False),
