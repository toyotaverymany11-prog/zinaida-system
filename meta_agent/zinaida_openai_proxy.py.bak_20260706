#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
================================================================================
 ZINAIDA SMART ROUTER v2.0  —  "Железобетонный" OpenAI-совместимый роутер
================================================================================
Порт: 8002  (эндпоинт /v1/chat/completions, /v1/models, /health, /status)

НАЗНАЧЕНИЕ
    Единая точка входа для всех LLM-запросов Hermes-агентов (Zinaida, Designer,
    Grigoriy). Прячет за собой пул из нескольких провайдеров и НИКОГДА не отдаёт
    "красную" ошибку в Hermes Studio — при полном отказе возвращает корректный
    OpenAI-ответ с человекочитаемым текстом.

КЛЮЧЕВЫЕ ПРИНЦИПЫ (долгосрочная надёжность, без костылей)
    1. МУЛЬТИ-КЛЮЧИ. У каждого провайдера может быть несколько API-ключей.
       При 429/401 на одном ключе — мгновенно пробуем следующий ключ, потом
       следующего провайдера. Никаких повторов на упавшем ключе.
    2. МГНОВЕННЫЙ ФОЛЛБЭК (<1 c). Короткий connect-timeout (4 c). Упал провайдер
       -> сразу следующий по порядку.
    3. КЭШ "МЁРТВЫХ". Провайдер/ключ, отдавший фатальную ошибку, помечается
       dead на COOLDOWN (по умолчанию 300 c) и не трогается до восстановления.
    4. HEALTH-CHECK НА СТАРТЕ. Параллельная лёгкая проверка всех провайдеров.
    5. ФОНОВЫЙ МОНИТОР. Каждые 10 минут проверяет "мёртвых" и возвращает
       восстановившихся в ротацию.
    6. OPENROUTER AUTO-FREE. Автопоиск бесплатных моделей через /models
       (pricing.prompt == 0). Кэш на 1 час.
    7. СЖАТИЕ КОНТЕНТА. Персональные лимиты на провайдера (GitHub Models жёстче),
       умная обрезка "голова+хвост" — защита от 413/400/422.
    8. ПОДРОБНОЕ ЛОГИРОВАНИЕ. Кто ответил, за сколько мс, кто и почему упал.

Автор изменений: модернизация 2026-07 (v2.0). Совместим по API с v1.
================================================================================
"""

import sys, os, json, time, uuid, logging, asyncio, warnings, base64, copy
from pathlib import Path
from typing import Optional, List, Dict, Any
from fastapi import FastAPI, Request
from fastapi.responses import JSONResponse, StreamingResponse
import uvicorn
import httpx

warnings.filterwarnings("ignore")
sys.path.insert(0, str(Path(__file__).parent))

# ----------------------------------------------------------------------------
# Логирование: отдельный формат [ROUTER], уровень INFO
# ----------------------------------------------------------------------------
logging.basicConfig(level=logging.INFO, format="%(asctime)s [ROUTER] %(message)s")
logger = logging.getLogger("zinaida_router")
# Приглушаем болтливый httpx (иначе он сам логирует каждый POST)
logging.getLogger("httpx").setLevel(logging.WARNING)

app = FastAPI(title="Zinaida Smart Router v2.0")

# ============================================================================
# 1. КОНФИГУРАЦИЯ И ЗАГРУЗКА ОКРУЖЕНИЯ
# ============================================================================
ENV_PATH = Path("/opt/zinaida/.env")

def load_env():
    """Подхватываем ключи из /opt/zinaida/.env (не перетирая уже заданные в среде)."""
    if ENV_PATH.exists():
        with open(ENV_PATH, "r", encoding="utf-8") as f:
            for line in f:
                line = line.strip()
                if "=" in line and not line.startswith("#"):
                    k, _, v = line.partition("=")
                    os.environ.setdefault(k.strip(), v.strip())
load_env()

def _keys(*names) -> List[str]:
    """Собирает непустые ключи из перечисленных ENV-переменных, без дублей."""
    out, seen = [], set()
    for n in names:
        v = (os.getenv(n, "") or "").strip()
        if v and v not in seen:
            seen.add(v)
            out.append(v)
    return out

# --- Лимиты сжатия контента (глобальные значения по умолчанию) ---------------
MAX_MSG_CHARS   = int(os.getenv("ROUTER_MAX_MSG_CHARS", "6000"))
MAX_TOTAL_CHARS = int(os.getenv("ROUTER_MAX_TOTAL_CHARS", "45000"))

# --- Тайминги ----------------------------------------------------------------
CONNECT_TIMEOUT   = float(os.getenv("ROUTER_CONNECT_TIMEOUT", "4.0"))    # мгновенный фоллбэк
GEN_READ_TIMEOUT  = float(os.getenv("ROUTER_GEN_TIMEOUT", "180.0"))      # генерация может быть долгой
HEALTH_TIMEOUT    = float(os.getenv("ROUTER_HEALTH_TIMEOUT", "10.0"))    # health/discovery
DEAD_COOLDOWN     = int(os.getenv("ROUTER_DEAD_COOLDOWN", "300"))        # 5 минут карантина
MONITOR_INTERVAL  = int(os.getenv("ROUTER_MONITOR_INTERVAL", "600"))     # фоновый монитор 10 мин

# ============================================================================
# 2. ОПИСАНИЕ ПРОВАЙДЕРОВ
#    keys      — список ключей (мульти-ключевая ротация)
#    max_total — персональный лимит суммарного payload (GitHub Models жёстче)
#    kind      — семейство API для специфичной подготовки payload
# ============================================================================
PROVIDERS: Dict[str, Dict[str, Any]] = {
    "mistral": {
        "url": "https://api.mistral.ai/v1/chat/completions",
        "keys": _keys("MISTRAL_API_KEY", "MISTRAL_API_KEY_2"),
        "model": "mistral-small-latest",
        "kind": "mistral",
        "max_total": 45000,
    },
    "github": {
        "url": "https://models.github.ai/inference/chat/completions",
        "keys": _keys("GITHUB_TOKEN", "GITHUB_TOKEN_2"),
        "model": "gpt-4.1-mini",
        "kind": "openai",
        "max_total": 18000,   # GitHub Models режет крупные payload -> 413. Держим низко.
    },
    "gigachat": {
        "url": "https://gigachat.devices.sberbank.ru/api/v1/chat/completions",
        "keys": ["oauth"],    # особый провайдер: ключ = OAuth-токен (см. get_gigachat_token)
        "model": os.getenv("GIGACHAT_MODEL", "GigaChat-Max"),
        "kind": "gigachat",
        "max_total": 40000,
    },
    "openrouter": {
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "keys": _keys("OPENROUTER_API_KEY_2", "OPENROUTER_API_KEY", "OPENROUTER_KEY"),
        "model": "meta-llama/llama-3.3-70b-instruct:free",  # стартовое; уточняется через /models
        "kind": "openrouter",
        "max_total": 40000,
    },
    "zhipu": {
        "url": "https://open.bigmodel.cn/api/paas/v4/chat/completions",
        "keys": _keys("ZHIPU_API_KEY"),
        "model": "glm-4-flash",
        "kind": "openai",
        "max_total": 40000,
    },
}

# Порядок фоллбэка. GigaChat — стабильный отечественный резерв выше нестабильных free.
ORDER_CHAT = ["mistral", "github", "gigachat", "openrouter", "zhipu"]
ORDER_CODE = ["mistral", "github", "openrouter", "gigachat", "zhipu"]

# Поля, которые вообще разрешено передавать провайдерам (белый список)
ALLOWED_KEYS = {"model", "messages", "stream", "max_tokens", "temperature", "top_p",
                "frequency_penalty", "presence_penalty", "stop", "user", "tools",
                "tool_choice", "parallel_tool_calls", "response_format"}

# ============================================================================
# 3. СОСТОЯНИЕ ПРОВАЙДЕРОВ (health / dead-cache)
#    Для каждого провайдера храним статус, время до восстановления и метрики.
# ============================================================================
_state: Dict[str, Dict[str, Any]] = {
    name: {"alive": True, "dead_until": 0.0, "last_error": "", "last_ok": 0.0,
           "last_latency_ms": 0, "ok_count": 0, "fail_count": 0}
    for name in PROVIDERS
}

def _mark_dead(name: str, reason: str, cooldown: int = DEAD_COOLDOWN):
    st = _state[name]
    st["alive"] = False
    st["dead_until"] = time.time() + cooldown
    st["last_error"] = reason
    st["fail_count"] += 1
    logger.warning("PROVIDER DOWN: %s помечен dead на %ss (%s)", name, cooldown, reason)

def _mark_alive(name: str, latency_ms: int = 0):
    st = _state[name]
    was_dead = not st["alive"]
    st["alive"] = True
    st["dead_until"] = 0.0
    st["last_ok"] = time.time()
    st["last_latency_ms"] = latency_ms
    st["ok_count"] += 1
    if was_dead:
        logger.info("PROVIDER RECOVERED: %s снова в ротации", name)

def _is_available(name: str) -> bool:
    """Провайдер доступен, если есть ключи и он не в карантине."""
    if not PROVIDERS[name]["keys"]:
        return False
    st = _state[name]
    if st["alive"]:
        return True
    if time.time() >= st["dead_until"]:
        # карантин истёк — даём шанс (half-open)
        st["alive"] = True
        st["dead_until"] = 0.0
        return True
    return False

# ============================================================================
# 4. СЖАТИЕ КОНТЕНТА (защита от 413/400/422/429)
# ============================================================================
def truncate_messages(messages, max_keep=24):
    """Оставляем системные сообщения + последние max_keep реплик диалога."""
    if len(messages) <= max_keep + 1:
        return messages
    system_msgs = [m for m in messages if m.get("role") == "system"]
    non_system = [m for m in messages if m.get("role") != "system"]
    recent = non_system[-max_keep:]
    while recent and recent[0].get("role") != "user":
        recent.pop(0)
    if not recent:
        recent = non_system[-max_keep:]
    return system_msgs + recent

def _truncate_text(text, limit):
    """Умная обрезка: голова(60%) + маркер + хвост. Сохраняет начало и конец."""
    if not isinstance(text, str) or len(text) <= limit:
        return text
    head = int(limit * 0.6)
    tail = max(limit - head - 60, 200)
    cut = len(text) - head - tail
    return text[:head] + f"\n\n...[обрезано {cut} символов для экономии контекста]...\n\n" + text[-tail:]

def shrink_messages(messages, max_msg=MAX_MSG_CHARS, max_total=MAX_TOTAL_CHARS):
    """Ограничивает размер каждого сообщения и суммарный payload."""
    out = []
    for m in messages:
        m = dict(m)
        c = m.get("content")
        if isinstance(c, str) and m.get("role") != "system":
            m["content"] = _truncate_text(c, max_msg)
        out.append(m)

    def total(msgs):
        return sum(len(x.get("content") or "") for x in msgs if isinstance(x.get("content"), str))

    limit = max_msg
    while total(out) > max_total and limit > 600:
        limit = int(limit * 0.6)
        for m in out:
            if isinstance(m.get("content"), str) and m.get("role") != "system":
                m["content"] = _truncate_text(m["content"], limit)
    # Крайний случай: режем и системные
    if total(out) > max_total:
        sys_limit = max(int(max_total * 0.5), 3000)
        for m in out:
            if isinstance(m.get("content"), str) and m.get("role") == "system":
                m["content"] = _truncate_text(m["content"], sys_limit)
    return out

def sanitize_payload(payload):
    return {k: v for k, v in payload.items() if k in ALLOWED_KEYS}

# ============================================================================
# 5. GIGACHAT: OAuth-токен + специфичная подготовка payload
# ============================================================================
def _fix_b64_padding(s: str) -> str:
    s = s.strip()
    missing = len(s) % 4
    if missing:
        s += "=" * (4 - missing)
    return s

_gc_token = {"value": None, "exp": 0.0}

async def get_gigachat_token(force=False) -> Optional[str]:
    now = time.time()
    if not force and _gc_token["value"] and now < _gc_token["exp"]:
        return _gc_token["value"]
    try:
        auth_key = os.getenv("GIGACHAT_AUTH_KEY", "").strip()
        if auth_key:
            b64_auth = _fix_b64_padding(auth_key)
        else:
            cid = os.getenv("GIGACHAT_CLIENT_ID", "")
            csec = os.getenv("GIGACHAT_CLIENT_SECRET", "")
            if not cid or not csec:
                return None
            b64_auth = base64.b64encode(f"{cid}:{csec}".encode()).decode()
        async with httpx.AsyncClient(verify=False, timeout=HEALTH_TIMEOUT) as client:
            resp = await client.post(
                "https://ngw.devices.sberbank.ru:9443/api/v2/oauth",
                headers={"Authorization": f"Basic {b64_auth}", "RqUID": str(uuid.uuid4()),
                         "Content-Type": "application/x-www-form-urlencoded"},
                data={"scope": "GIGACHAT_API_PERS"},
            )
            resp.raise_for_status()
            data = resp.json()
            tok = data.get("access_token")
            exp_ms = data.get("expires_at", 0)
            exp = (exp_ms / 1000.0) if exp_ms else (now + 1800)
            _gc_token["value"] = tok
            _gc_token["exp"] = exp - 300
            logger.info("GigaChat token refreshed (valid ~%.0f min)", max(0, (_gc_token["exp"] - now) / 60))
            return tok
    except Exception as e:
        logger.warning("GigaChat token failed: %s", e)
        return None

def _gigachat_clean_messages(messages):
    """GigaChat строг к формату: только один system (первым), роли должны чередоваться,
    content обязателен и строковый. Схлопываем и приводим к валиду."""
    cleaned = []
    system_taken = False
    for m in messages:
        role = m.get("role", "user")
        content = m.get("content")
        if not isinstance(content, str):
            content = json.dumps(content, ensure_ascii=False) if content is not None else ""
        if role == "system":
            if system_taken:
                # второй system -> склеиваем в user-контекст
                role = "user"
            else:
                system_taken = True
        if role == "tool":
            role = "user"
        if not content.strip():
            continue
        # чередование ролей: склеиваем подряд идущие одинаковые роли
        if cleaned and cleaned[-1]["role"] == role and role != "system":
            cleaned[-1]["content"] += "\n\n" + content
        else:
            cleaned.append({"role": role, "content": content})
    # гарантируем, что последнее сообщение — от user
    if cleaned and cleaned[-1]["role"] == "assistant":
        cleaned.append({"role": "user", "content": "Продолжай."})
    return cleaned

# ============================================================================
# 6. OPENROUTER: автопоиск бесплатных моделей
# ============================================================================
_or_free = {"models": [], "exp": 0.0}

async def get_openrouter_free_model() -> str:
    """Возвращает id рабочей бесплатной модели OpenRouter. Кэш на 1 час.
    Фильтр: pricing.prompt == 0 и pricing.completion == 0."""
    now = time.time()
    if _or_free["models"] and now < _or_free["exp"]:
        return _or_free["models"][0]
    keys = PROVIDERS["openrouter"]["keys"]
    if not keys:
        return PROVIDERS["openrouter"]["model"]
    try:
        async with httpx.AsyncClient(verify=False, timeout=HEALTH_TIMEOUT) as client:
            resp = await client.get(
                "https://openrouter.ai/api/v1/models",
                headers={"Authorization": f"Bearer {keys[0]}"},
            )
            resp.raise_for_status()
            data = resp.json().get("data", [])
            free = []
            for m in data:
                pr = m.get("pricing", {}) or {}
                try:
                    if float(pr.get("prompt", "1")) == 0.0 and float(pr.get("completion", "1")) == 0.0:
                        free.append(m.get("id"))
                except (ValueError, TypeError):
                    continue
            # предпочитаем крупные инструктивные модели
            preferred = [x for x in free if any(k in x.lower() for k in
                         ["llama-3.3", "llama-3.1-70", "qwen-2.5-72", "deepseek", "gemma-2"])]
            ordered = preferred + [x for x in free if x not in preferred]
            if ordered:
                _or_free["models"] = ordered
                _or_free["exp"] = now + 3600
                logger.info("OpenRouter: найдено %d бесплатных моделей, выбрана %s",
                            len(ordered), ordered[0])
                return ordered[0]
    except Exception as e:
        logger.warning("OpenRouter free-model discovery failed: %s", e)
    return PROVIDERS["openrouter"]["model"]

# ============================================================================
# 7. ПОДГОТОВКА PAYLOAD + ЗАГОЛОВКОВ ДЛЯ КОНКРЕТНОГО ПРОВАЙДЕРА/КЛЮЧА
# ============================================================================
def is_code_request(messages) -> bool:
    if not messages:
        return False
    last = (messages[-1].get("content") or "")
    if not isinstance(last, str):
        return False
    last = last.lower()
    kw = ["код", "скрипт", "python", "html", "css", "javascript", "function",
          "def ", "class ", "напиши программу", "code", "script", "api", "json", "sql"]
    return any(k in last for k in kw)

async def prepare_payload_and_headers(name: str, key: str, payload: dict,
                                      max_msg=MAX_MSG_CHARS, max_total=None):
    p = PROVIDERS[name]
    if max_total is None:
        max_total = p.get("max_total", MAX_TOTAL_CHARS)
    headers = {"Content-Type": "application/json"}
    work = sanitize_payload(copy.deepcopy(payload))
    msgs = truncate_messages(work.get("messages", []))
    msgs = shrink_messages(msgs, max_msg=max_msg, max_total=max_total)
    work["messages"] = msgs
    work["model"] = p["model"]
    kind = p["kind"]

    if kind == "openrouter":
        work["model"] = await get_openrouter_free_model()
        headers["Authorization"] = f"Bearer {key}"
        headers.update({"HTTP-Referer": "https://zinaida.local", "X-Title": "ZinaidaRouter"})
    elif kind == "gigachat":
        token = await get_gigachat_token()
        if not token:
            raise Exception("No GigaChat token")
        headers["Authorization"] = f"Bearer {token}"
        # GigaChat не принимает tools/response_format от Hermes -> убираем
        for bad in ("tools", "tool_choice", "parallel_tool_calls", "response_format"):
            work.pop(bad, None)
        work["messages"] = _gigachat_clean_messages(work["messages"])
        # клэмп параметров под допустимые диапазоны GigaChat
        if "temperature" in work:
            try: work["temperature"] = min(max(float(work["temperature"]), 0.01), 2.0)
            except Exception: work.pop("temperature", None)
    elif kind == "mistral":
        headers["Authorization"] = f"Bearer {key}"
        # Mistral: только один system-блок
        filtered = []
        for msg in work.get("messages", []):
            if msg.get("role") == "system" and len(filtered) > 0:
                continue
            filtered.append(msg)
        work["messages"] = filtered
    elif kind == "openai":
        headers["Authorization"] = f"Bearer {key}"
        if name == "github":
            work["model"] = "gpt-4.1-mini"
    else:
        headers["Authorization"] = f"Bearer {key}"
    return headers, work

# ============================================================================
# 8. ВЫЗОВ ПРОВАЙДЕРА (не-стрим) С РОТАЦИЕЙ КЛЮЧЕЙ И САМОЛЕЧЕНИЕМ
# ============================================================================
def _status_of(exc):
    resp = getattr(exc, "response", None)
    return resp.status_code if resp is not None else None

async def _post_once(name, key, data, timeout, max_msg, max_total):
    p = PROVIDERS[name]
    headers, work = await prepare_payload_and_headers(name, key, data, max_msg, max_total)
    async with httpx.AsyncClient(verify=False,
                                 timeout=httpx.Timeout(timeout, read=timeout, connect=CONNECT_TIMEOUT)) as client:
        resp = await client.post(p["url"], headers=headers, json=work)
        resp.raise_for_status()
        return resp.json()

async def try_provider(name, data, timeout) -> Optional[dict]:
    """Пробуем провайдера по всем его ключам. Возвращает JSON или None.
    Ротация: 429/401 -> следующий ключ; 400/413/422 -> ужать и повторить один раз."""
    p = PROVIDERS[name]
    keys = p["keys"] if p["kind"] != "gigachat" else ["oauth"]
    t0 = time.time()
    for ki, key in enumerate(keys):
        for attempt in range(2):
            mm = MAX_MSG_CHARS if attempt == 0 else MAX_MSG_CHARS // 2
            mt = p.get("max_total", MAX_TOTAL_CHARS) if attempt == 0 else p.get("max_total", MAX_TOTAL_CHARS) // 2
            try:
                result = await _post_once(name, key, data, timeout, mm, mt)
                latency = int((time.time() - t0) * 1000)
                _mark_alive(name, latency)
                logger.info("OK <- %s (key#%d, %d ms)", name, ki + 1, latency)
                return result
            except httpx.HTTPStatusError as e:
                code = _status_of(e)
                logger.warning("FAIL <- %s key#%d HTTP %s", name, ki + 1, code)
                if code == 401 and name == "gigachat":
                    await get_gigachat_token(force=True)
                    continue
                if code in (401, 403):
                    break  # ключ невалиден -> следующий ключ
                if code == 429:
                    break  # лимит на этом ключе -> следующий ключ
                if code in (400, 413, 422):
                    if attempt == 0:
                        continue  # ужать и повторить
                    break
                break
            except (httpx.ConnectError, httpx.ConnectTimeout, httpx.ReadTimeout) as e:
                logger.warning("FAIL <- %s key#%d network: %s", name, ki + 1, type(e).__name__)
                break
            except Exception as e:
                logger.warning("FAIL <- %s key#%d error: %s", name, ki + 1, e)
                break
    _mark_dead(name, f"all keys failed")
    return None

# ============================================================================
# 9. GRACEFUL FALLBACK (никакого голого 503)
# ============================================================================
def _degraded_text() -> str:
    dead = [n for n in PROVIDERS if not _is_available(n)]
    if dead:
        return ("Провайдеры временно недоступны (" + ", ".join(dead) +
                "). Автовосстановление уже запущено — повтори запрос через минуту.")
    return "Провайдеры сейчас перегружены. Повтори запрос через минуту — я отвечу."

def _fallback_response():
    return {
        "id": "chatcmpl-fallback", "object": "chat.completion",
        "created": int(time.time()), "model": "Zinaida-Router",
        "choices": [{"index": 0,
                     "message": {"role": "assistant", "content": _degraded_text()},
                     "finish_reason": "stop"}],
        "usage": {"prompt_tokens": 0, "completion_tokens": 0, "total_tokens": 0},
    }

# ============================================================================
# 10. HTTP-ЭНДПОИНТЫ
# ============================================================================
@app.post("/v1/chat/completions")
async def chat(request: Request):
    try:
        data = await request.json()
        is_stream = data.get("stream", False)
        timeout = float(data.get("timeout", GEN_READ_TIMEOUT))
        base_order = ORDER_CODE if is_code_request(data.get("messages", [])) else ORDER_CHAT
        # доступные (не в карантине) — вперёд, остальные — в конец как крайний резерв
        order = [n for n in base_order if _is_available(n)] + \
                [n for n in base_order if not _is_available(n) and PROVIDERS[n]["keys"]]

        if is_stream:
            for name in order:
                p = PROVIDERS[name]
                keys = p["keys"] if p["kind"] != "gigachat" else ["oauth"]
                for ki, key in enumerate(keys):
                    for attempt in range(2):
                        mm = MAX_MSG_CHARS if attempt == 0 else MAX_MSG_CHARS // 2
                        mt = p.get("max_total", MAX_TOTAL_CHARS) if attempt == 0 else p.get("max_total", MAX_TOTAL_CHARS) // 2
                        try:
                            headers, work = await prepare_payload_and_headers(name, key, data, mm, mt)
                            client = httpx.AsyncClient(verify=False,
                                        timeout=httpx.Timeout(timeout, read=timeout, connect=CONNECT_TIMEOUT))
                            resp = await client.send(
                                client.build_request("POST", p["url"], headers=headers, json=work),
                                stream=True)
                            if resp.status_code >= 400:
                                sc = resp.status_code
                                await resp.aclose(); await client.aclose()
                                logger.warning("FAIL(stream) <- %s key#%d HTTP %s", name, ki + 1, sc)
                                if sc == 401 and name == "gigachat":
                                    await get_gigachat_token(force=True)
                                if sc in (400, 413, 422) and attempt == 0:
                                    continue
                                break
                            _mark_alive(name)
                            logger.info("OK(stream) <- %s key#%d", name, ki + 1)
                            async def stream_gen(r, c):
                                try:
                                    async for chunk in r.aiter_lines():
                                        if chunk:
                                            yield f"{chunk}\n\n"
                                finally:
                                    await r.aclose(); await c.aclose()
                            return StreamingResponse(stream_gen(resp, client), media_type="text/event-stream")
                        except Exception as e:
                            logger.warning("FAIL(stream) <- %s key#%d %s", name, ki + 1, type(e).__name__)
                            break
                _mark_dead(name, "stream failed")
            # все упали -> SSE-заглушка (не красный 503)
            async def fb_gen():
                payload = {"id": "chatcmpl-fallback", "object": "chat.completion.chunk",
                           "created": int(time.time()), "model": "Zinaida-Router",
                           "choices": [{"index": 0, "delta": {"role": "assistant", "content": _degraded_text()},
                                        "finish_reason": None}]}
                yield f"data: {json.dumps(payload, ensure_ascii=False)}\n\n"
                payload["choices"][0]["delta"] = {}
                payload["choices"][0]["finish_reason"] = "stop"
                yield f"data: {json.dumps(payload, ensure_ascii=False)}\n\n"
                yield "data: [DONE]\n\n"
            return StreamingResponse(fb_gen(), media_type="text/event-stream")

        # НЕ-стрим путь
        for name in order:
            result = await try_provider(name, data, timeout)
            if result is not None:
                return JSONResponse(result)
        logger.error("ВСЕ ПРОВАЙДЕРЫ УПАЛИ -> graceful fallback")
        return JSONResponse(_fallback_response())
    except Exception as e:
        logger.error("Router crash: %s", e)
        return JSONResponse({"error": str(e)}, status_code=500)

@app.get("/v1/models")
async def list_models():
    return {"object": "list", "data": [{"id": "Zinaida-Router", "object": "model", "owned_by": "local"}]}

@app.get("/health")
async def health():
    return {"status": "ok", "port": 8002, "version": "2.0",
            "max_msg_chars": MAX_MSG_CHARS, "max_total_chars": MAX_TOTAL_CHARS}

@app.get("/status")
async def status():
    """Живая диагностика: статус каждого провайдера, метрики, карантин."""
    now = time.time()
    providers = {}
    for name, p in PROVIDERS.items():
        st = _state[name]
        providers[name] = {
            "available": _is_available(name),
            "keys": len(p["keys"]),
            "model": p["model"],
            "alive": st["alive"],
            "dead_for_sec": max(0, int(st["dead_until"] - now)) if not st["alive"] else 0,
            "last_error": st["last_error"],
            "last_latency_ms": st["last_latency_ms"],
            "ok_count": st["ok_count"],
            "fail_count": st["fail_count"],
        }
    return {"router": "Zinaida Smart Router v2.0", "order_chat": ORDER_CHAT,
            "order_code": ORDER_CODE, "providers": providers,
            "openrouter_free_model": _or_free["models"][0] if _or_free["models"] else None}

# ============================================================================
# 11. HEALTH-CHECK (лёгкая проверка провайдера крошечным запросом)
# ============================================================================
async def _probe(name: str) -> bool:
    p = PROVIDERS[name]
    keys = p["keys"] if p["kind"] != "gigachat" else ["oauth"]
    if not keys:
        return False
    probe = {"messages": [{"role": "user", "content": "ping"}], "max_tokens": 1, "stream": False}
    t0 = time.time()
    try:
        headers, work = await prepare_payload_and_headers(name, keys[0], probe, 500, 2000)
        async with httpx.AsyncClient(verify=False,
                    timeout=httpx.Timeout(HEALTH_TIMEOUT, connect=CONNECT_TIMEOUT)) as client:
            resp = await client.post(p["url"], headers=headers, json=work)
            # 200 или даже 429 значит эндпоинт жив и ключ валиден по сети;
            # но для health засчитываем только 2xx
            if resp.status_code < 300:
                _mark_alive(name, int((time.time() - t0) * 1000))
                return True
            # 429 = временный лимит, не считаем "мёртвым" навсегда
            if resp.status_code == 429:
                logger.info("HEALTH %s: 429 (лимит, но эндпоинт жив)", name)
                return False
            _mark_dead(name, f"health HTTP {resp.status_code}")
            return False
    except Exception as e:
        _mark_dead(name, f"health {type(e).__name__}")
        return False

async def health_check_all(reason="startup"):
    logger.info("HEALTH-CHECK (%s): проверяю провайдеров...", reason)
    results = await asyncio.gather(*[_probe(n) for n in PROVIDERS], return_exceptions=True)
    alive = [n for n, r in zip(PROVIDERS, results) if r is True]
    logger.info("HEALTH-CHECK (%s): живы %d/%d -> %s",
                reason, len(alive), len(PROVIDERS), ", ".join(alive) or "никого")

async def background_monitor():
    """Фоновый монитор: каждые MONITOR_INTERVAL секунд перепроверяет провайдеров
    (в первую очередь помеченных dead) и возвращает восстановившихся в ротацию."""
    while True:
        await asyncio.sleep(MONITOR_INTERVAL)
        try:
            await health_check_all(reason="monitor")
            # обновим и список бесплатных моделей OpenRouter
            await get_openrouter_free_model()
        except Exception as e:
            logger.warning("monitor tick failed: %s", e)

@app.on_event("startup")
async def _on_startup():
    logger.info("=" * 60)
    logger.info("ZINAIDA SMART ROUTER v2.0 стартует на :8002")
    for name, p in PROVIDERS.items():
        logger.info("  провайдер %-10s ключей=%d модель=%s", name, len(p["keys"]), p["model"])
    logger.info("=" * 60)
    # неблокирующий health-check + фоновый монитор
    asyncio.create_task(health_check_all(reason="startup"))
    asyncio.create_task(get_openrouter_free_model())
    asyncio.create_task(background_monitor())

if __name__ == "__main__":
    uvicorn.run(app, host="127.0.0.1", port=8002, log_level="info")
