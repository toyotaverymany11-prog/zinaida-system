    def _needs_programmer(self, msg: str) -> bool:
        keywords = ["напиши скрипт", "напиши код", "создай программу", "разработай", "парсер", "бот", "функцию", "алгоритм", "исправь код", "допиши код"]
        return any(k in msg.lower() for k in keywords)

    async def _call_programmer(self, task: str) -> str:
        """ДЕЛЕГИРУЕМ АГЕНТУ НА ПОРТУ 8002"""
        try:
            async with aiohttp.ClientSession() as session:
                async with session.post(
                    "http://localhost:8002/code",
                    json={"task": task, "language": "python"},
                    timeout=aiohttp.ClientTimeout(total=30)
                ) as resp:
                    result = await resp.json()
                    return f"Программист создал: {result.get('file')}\n{result.get('code', '')[:400]}"
        except Exception as e:
            return f"Ошибка программиста: {e}"
        if not code:
            return "Ошибка генерации кода"
        ts = datetime.now().strftime("%Y%m%d_%H%M%S")
        path = f"{PROJECT_ROOT}/code_{ts}.py"
        Tools.create_file(path, code)
        test_result = Tools.execute_python(code)
        if "ERROR" in test_result or "TIMEOUT" in test_result:
            fixed = await LLMClient.call("github", "openai/gpt-4.1", [
                {"role": "system", "content": "Исправь ошибки в коде."},
                {"role": "user", "content": f"Код:\n{code}\n\nОшибка:\n{test_result}"}
            ], max_tokens=4096, timeout=60)
            if fixed:
                Tools.create_file(path, fixed)
                test_result = Tools.execute_python(fixed)
                if "ERROR" not in test_result and "TIMEOUT" not in test_result:
                    return f"Файл: {path}\nКод исправлен и работает."
        review = await LLMClient.call("github", "meta/llama-3.3-70b-instruct", [
            {"role": "system", "content": "Найди ошибки в коде. Если ошибок нет, скажи 'OK'."},
            {"role": "user", "content": code}
        ], max_tokens=1024, timeout=45)
        if review and "OK" not in review:
            return f"Файл: {path}\nРевью: {review[:300]}"
        return f"Файл: {path}\nКод готов и проверен."

    async def process(self, user_id: int, message: str) -> str:
        task_id = self.db.create_task(user_id, message)
        ts = datetime.now().strftime("%Y-%m-%d_%H-%M-%S")
        Tools.create_file(f"{MEMORY_ROOT}/chat_logs/{ts}_{user_id}.txt", message)

        system_prompt = self._system_prompt(message)
        messages = [
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": message}
        ]

        # Роутер с fallback
        providers = [
            ("zhipu", "glm-4-flash"),
            ("github", "openai/gpt-4.1-mini"),
            ("mistral", "mistral-large-latest"),
            ("gigachat", "GigaChat")
        ]
        reply = None
        for provider, model in providers:
            try:
                reply = await LLMClient.call(provider, model, messages, max_tokens=2048, timeout=60)
                if reply:
                    self.db.update_task(task_id, "done", reply, model)
                    break
            except:
                continue

        if not reply:
            reply = "Извини, все нейросети сейчас недоступны."
            self.db.update_task(task_id, "failed", reply)

        if self._needs_programmer(message):
            code_result = await self._call_programmer(message)
            reply = code_result  # Отдаем только результат Программиста, без дубля

        if any(w in message.lower() for w in ["зафиксируй", "сохрани", "запомни"]):
            category = "ideas"
            if "правило" in message.lower():
                category = "rules"
            elif "задача" in message.lower():
                category = "tasks"
            elif "решение" in message.lower():
                category = "decisions"
            self.db.save_memory(category, message)
            Tools.create_file(f"{MEMORY_ROOT}/{category}/{ts}.txt", message)
            reply = (reply or "") + "\n📌 Сохранено"

        return reply

