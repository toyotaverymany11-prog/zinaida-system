class Tools:
    @staticmethod
    def _safe_path(path: str) -> Path:
        full = Path(path).resolve()
        # Разрешаем projects, memory, logs
        allowed = [
            Path("/opt/zinaida/projects").resolve(),
            Path("/opt/zinaida/memory").resolve(),
            Path("/opt/zinaida/logs").resolve(),
        ]
        if not any(str(full).startswith(str(r)) for r in allowed):
            raise ValueError(f"Путь вне разрешённых директорий: {full}")
        return full

    @staticmethod
    def create_file(path: str, content: str) -> str:
        try:
            p = Tools._safe_path(path)
            p.parent.mkdir(parents=True, exist_ok=True)
            p.write_text(content, encoding='utf-8')
            return f"OK: {path}"
        except Exception as e:
            return f"ERROR: {e}"

    @staticmethod
    def read_file(path: str) -> str:
        try:
            p = Tools._safe_path(path)
            if not p.exists():
                return f"Файл не найден: {path}"
            return p.read_text(encoding='utf-8')
        except Exception as e:
            return f"ERROR: {e}"

    @staticmethod
    def execute_python(code: str) -> str:
        try:
            r = subprocess.run(["python3", "-c", code], capture_output=True, text=True, timeout=30, cwd=PROJECT_ROOT)
            output = (r.stdout.strip() or r.stderr.strip()).replace('\n', ' ')
            return output
        except subprocess.TimeoutExpired:
            return "TIMEOUT: 30с"
        except Exception as e:
            return f"ERROR: {e}"

    @staticmethod
    def execute_bash(command: str) -> str:
        safe_commands = ["pip", "python3", "ls", "cat", "echo", "mkdir", "cp", "mv", "grep", "find", "wc", "head", "tail", "git"]
        first_word = command.strip().split()[0] if command.strip() else ""
        if first_word not in safe_commands and not command.startswith("./"):
            return f"BLOCKED: '{first_word}' не в белом списке"
        try:
            r = subprocess.run(["bash", "-c", command], capture_output=True, text=True, timeout=30, cwd=PROJECT_ROOT)
            output = (r.stdout.strip() or r.stderr.strip()).replace('\n', ' ')
            return output
        except subprocess.TimeoutExpired:
            return "TIMEOUT: 30с"
        except Exception as e:
            return f"ERROR: {e}"

class Database:
    def __init__(self, path=DB_PATH):
        self.path = path
        os.makedirs(os.path.dirname(path), exist_ok=True)
        self.conn = sqlite3.connect(path, check_same_thread=False)
        self.conn.execute("PRAGMA journal_mode=WAL")
        c = self.conn.cursor()
        c.execute("CREATE TABLE IF NOT EXISTS tasks (id INTEGER PRIMARY KEY AUTOINCREMENT, user_id INTEGER, message TEXT, status TEXT, result TEXT, model_used TEXT, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP, completed_at TIMESTAMP)")
        c.execute("CREATE TABLE IF NOT EXISTS task_steps (id INTEGER PRIMARY KEY AUTOINCREMENT, task_id INTEGER, step_number INTEGER, tool_name TEXT, tool_args TEXT, tool_result TEXT, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP)")
        c.execute("CREATE TABLE IF NOT EXISTS memory (id INTEGER PRIMARY KEY AUTOINCREMENT, category TEXT, content TEXT, source TEXT, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP)")
        self.conn.commit()

    def create_task(self, uid, msg):
        c = self.conn.cursor()
        c.execute("INSERT INTO tasks (user_id, message) VALUES (?,?)", (uid, msg))
        self.conn.commit()
        return c.lastrowid

    def update_task(self, tid, status, result=None, model=None):
        c = self.conn.cursor()
        if result and model:
            c.execute("UPDATE tasks SET status=?, result=?, model_used=?, completed_at=CURRENT_TIMESTAMP WHERE id=?", (status, result, model, tid))
        elif result:
            c.execute("UPDATE tasks SET status=?, result=?, completed_at=CURRENT_TIMESTAMP WHERE id=?", (status, result, tid))
        else:
            c.execute("UPDATE tasks SET status=?, completed_at=CURRENT_TIMESTAMP WHERE id=?", (status, tid))
        self.conn.commit()

    def add_step(self, tid, step, tool, args, res):
        c = self.conn.cursor()
        c.execute("INSERT INTO task_steps (task_id, step_number, tool_name, tool_args, tool_result) VALUES (?,?,?,?,?)", (tid, step, tool, json.dumps(args, ensure_ascii=False), res))
        self.conn.commit()

    def save_memory(self, category, content, source="zinaida"):
        c = self.conn.cursor()
        c.execute("INSERT INTO memory (category, content, source) VALUES (?,?,?)", (category, content, source))
        self.conn.commit()

    def get_memory(self, category, limit=10):
        c = self.conn.cursor()
        c.execute("SELECT content, created_at FROM memory WHERE category=? ORDER BY created_at DESC LIMIT ?", (category, limit))
        return [{"content": r[0], "date": r[1]} for r in c.fetchall()]

def search_knowledge(query: str, limit: int = 2) -> str:
    MEMORY_DIR = os.path.join(BASE_DIR, "memory", "knowledge", "MEMORY")
    results = []
    query_words = query.lower().split()
    if not query_words:
        return ""
    for filename in os.listdir(MEMORY_DIR):
        if not filename.endswith(".md"):
            continue
        filepath = os.path.join(MEMORY_DIR, filename)
        try:
            with open(filepath, 'r', encoding='utf-8') as f:
                content = f.read()
        except:
            continue
        if any(word in content.lower() for word in query_words):
            header_match = re.search(r'# (.+)', content)
            header = header_match.group(1) if header_match else filename
            first_match_pos = len(content)
            for word in query_words:
                pos = content.lower().find(word)
                if pos != -1 and pos < first_match_pos:
                    first_match_pos = pos
            start = max(0, first_match_pos - 150)
            end = min(len(content), first_match_pos + 450)
            snippet = content[start:end]
            if snippet.startswith("---"):
                snippet = "---\n..." + snippet.split("---", 2)[2]
            results.append(f"[{filename} | {header}]\n{snippet}")
        if len(results) >= limit:
            break
    return "\n---\n".join(results) if results else ""

class LLMClient:
    @staticmethod
    async def call(provider: str, model: str, messages: list, max_tokens=4096, timeout=60) -> Optional[str]:
        loop = asyncio.get_event_loop()
        if provider == "gigachat":
            return await loop.run_in_executor(None, LLMClient._call_gigachat, model, messages, max_tokens, timeout)
        urls = {
            "zhipu": "https://open.bigmodel.cn/api/paas/v4/chat/completions",
            "github": "https://models.github.ai/inference/chat/completions",
            "openrouter": "https://openrouter.ai/api/v1/chat/completions",
            "mistral": "https://api.mistral.ai/v1/chat/completions"
        }
        return await loop.run_in_executor(None, LLMClient._call_openai_compatible, urls[provider], KEYS[provider], model, messages, max_tokens, timeout)

    @staticmethod
    def _call_openai_compatible(url, key, model, messages, max_tokens, timeout):
        headers = {"Authorization": f"Bearer {key}", "Content-Type": "application/json"}
        payload = {"model": model, "messages": messages, "max_tokens": max_tokens, "temperature": 0.3}
        try:
            r = requests.post(url, headers=headers, json=payload, timeout=timeout)
            if r.status_code == 200:
                return r.json()["choices"][0]["message"]["content"]
            return None
        except:
            return None

    @staticmethod
    def _call_gigachat(model, messages, max_tokens, timeout):
        try:
            r = requests.post("https://ngw.devices.sberbank.ru:9443/api/v2/oauth",
                headers={"Content-Type": "application/x-www-form-urlencoded", "Accept": "application/json",
                         "RqUID": str(uuid.uuid4()), "Authorization": f"Basic {KEYS['gigachat_auth']}"},
                data={"scope": "GIGACHAT_API_PERS"}, timeout=30, verify=False)
            if r.status_code != 200:
                return None
            token = r.json()["access_token"]
            r2 = requests.post("https://gigachat.devices.sberbank.ru/api/v1/chat/completions",
                headers={"Authorization": f"Bearer {token}", "Content-Type": "application/json"},
                json={"model": model, "messages": messages, "max_tokens": max_tokens}, timeout=timeout, verify=False)
            if r2.status_code == 200:
                return r2.json()["choices"][0]["message"]["content"]
            return None
        except:
            return None

