import sys, os, json, time, uuid, logging, asyncio
from pathlib import Path
from fastapi import FastAPI, Request
from fastapi.responses import JSONResponse, StreamingResponse
import uvicorn

sys.path.insert(0, str(Path(__file__).parent))

logging.basicConfig(level=logging.INFO, format="%(asctime)s [CORE-PROXY] %(message)s")
logger = logging.getLogger(__name__)

try:
    from router_zinaida import call_zinaida
    from router_grigoriy import call_grigoriy
except ImportError as e:
    logger.error(f"Router import failed: {e}")
    def call_zinaida(*args, **kwargs): return f"❌ Router import failed: {e}"
    def call_grigoriy(*args, **kwargs): return f"❌ Router import failed: {e}"

app = FastAPI(title="Zinaida Core Proxy")

@app.get("/status")
async def status():
    return {"alive": True, "port": 8000}

async def stream_generator(content: str):
    chunk = {
        "id": f"chatcmpl-{uuid.uuid4().hex[:8]}",
        "object": "chat.completion.chunk",
        "created": int(time.time()),
        "model": "router-dispatch",
        "choices": [{"index": 0, "delta": {"content": content}, "finish_reason": "stop"}]
    }
    yield f"data: {json.dumps(chunk)}\n\n"
    yield "data: [DONE]\n\n"

@app.post("/v1/chat/completions")
async def chat(request: Request):
    try:
        data = await request.json()
        messages = data.get("messages", [])
        if not messages:
            return JSONResponse({"error": "No messages provided"}, status_code=400)

        user_text = messages[-1].get("content", "")
        system_prompt = ""
        for msg in messages:
            if msg.get("role") == "system":
                system_prompt = msg.get("content", "")
                break

        code_triggers = ["код", "скрипт", "функция", "класс", "алгоритм", "def ", "import ", "python", "bash", "js", "json", "html", "sql", "debug", "рефакторинг"]
        is_code = any(kw in user_text.lower() for kw in code_triggers)
        task_type = "code" if is_code else "chat"

        # Выносим блокирующие HTTP-вызовы в фоновый пул потоков
        if task_type == "code":
            raw_response = await asyncio.to_thread(call_grigoriy, prompt=user_text, system=system_prompt, task_type=task_type)
        else:
            raw_response = await asyncio.to_thread(call_zinaida, prompt=user_text, system=system_prompt, task_type=task_type)

        if "❌" in raw_response or "All providers failed" in raw_response:
            return JSONResponse({"error": raw_response}, status_code=503)

        is_stream = data.get("stream", False)
        if is_stream:
            return StreamingResponse(stream_generator(raw_response), media_type="text/event-stream")

        return JSONResponse({
            "id": f"chatcmpl-{uuid.uuid4().hex[:8]}",
            "object": "chat.completion",
            "created": int(time.time()),
            "model": "router-dispatch",
            "choices": [{
                "index": 0,
                "message": {"role": "assistant", "content": raw_response},
                "finish_reason": "stop"
            }],
            "usage": {
                "prompt_tokens": len(user_text),
                "completion_tokens": len(raw_response.split()),
                "total_tokens": len(user_text) + len(raw_response.split())
            }
        })
    except Exception as e:
        logger.error(f"Proxy error: {e}")
        return JSONResponse({"error": str(e)}, status_code=500)

if __name__ == "__main__":
    uvicorn.run(app, host="0.0.0.0", port=8000)
