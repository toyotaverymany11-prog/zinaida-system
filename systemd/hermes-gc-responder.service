[Unit]
Description=Hermes Group Chat @Olya Responder
After=network.target hermes-web-ui.service
Requires=hermes-web-ui.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 -u /opt/zinaida/scripts/gc_responder.py
WorkingDirectory=/opt/zinaida/scripts
Restart=always
RestartSec=10
User=root
StandardOutput=append:/var/log/gc-responder.log
StandardError=append:/var/log/gc-responder.log

[Install]
WantedBy=multi-user.target
